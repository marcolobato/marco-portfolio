---
// [slug].astro — Individual post page
// The filename [slug] is a special Astro convention meaning "dynamic route".
// Astro will generate one page per post, e.g. /writing/learning-in-public
// getStaticPaths() tells Astro which slugs exist at build time.

import { getCollection, render } from 'astro:content';
import '../../styles/global.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';

// getStaticPaths runs once at build time and returns one entry per post.
// Each entry becomes a separate page URL.
export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

// props.post is the individual post data passed from getStaticPaths above.
const { post } = Astro.props;

// render() converts the Markdown body into HTML.
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Marco Lobato`}>

    <Nav />

    <main class="post-main">
      <div class="post-container">

        <!-- Back link -->
        <a href="/#writing" class="post-back">← Notes</a>

        <!-- Post header -->
        <header class="post-header">
          <p class="post-date">
            <!-- toLocaleDateString formats the date as "January 15, 2024" -->
            {post.data.date.toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <h1 class="post-title">{post.data.title}</h1>
        </header>

        <!-- Cover image — shown if the post's frontmatter includes an `image` field -->
        {post.data.image && (
          <img src={post.data.image} alt={post.data.title} class="post-cover" />
        )}

        <!-- Post body — Content is the rendered Markdown from the .md file -->
        <div class="post-body">
          <Content />
        </div>

      </div>
    </main>

</BaseLayout>


<style>
  /* Nav styles live in src/components/Nav.astro */

  .post-main {
    padding-block: var(--space-3xl);
  }

  .post-container {
    max-width: 680px; /* narrower than the site container — ideal for long-form reading */
    margin-inline: auto;
    padding-inline: var(--space-xl);
  }

  .post-back {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-royal-blue);
    margin-bottom: var(--space-2xl);
    transition: color 0.2s ease;
  }
  .post-back:hover { color: var(--color-navy); }

  .post-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-slate);
  }

  .post-date {
    font-size: var(--text-sm);
    color: var(--color-slate);
    margin-bottom: var(--space-sm);
    max-width: none;
  }

  .post-title {
    /* h1 from global.css */
    margin-bottom: var(--space-md);
  }

  .post-description {
    font-size: var(--text-lg);
    color: var(--color-charcoal);
    margin-bottom: 0;
  }

  /* Post body — styles the rendered Markdown content */
  .post-body h2 { margin-top: var(--space-2xl); margin-bottom: var(--space-md); }
  .post-body h3 { margin-top: var(--space-xl);  margin-bottom: var(--space-sm); }
  .post-body p  { line-height: var(--leading-loose); }

  /* Links — mirrors the .text-link component from the design system.
     :global() is needed because <a> tags come from rendered markdown
     and don't receive Astro's scope attribute. */
  :global(.post-body a) {
    color: var(--color-royal-blue);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  :global(.post-body a:hover) {
    color: var(--color-heading);
    text-decoration: underline;
  }

  /* Restore bullets and numbers — the global reset strips these from all lists.
     :global() is required here because <ul> and <li> come from rendered markdown
     via <Content />, so they don't receive Astro's scope attribute. Without
     :global(), the scoped selector won't match those elements. */
  :global(.post-body ul) {
    list-style: disc;
    padding-left: var(--space-xl);
    margin-bottom: var(--space-md);
  }
  :global(.post-body ol) {
    list-style: decimal;
    padding-left: var(--space-xl);
    margin-bottom: var(--space-md);
  }
  :global(.post-body li) {
    line-height: var(--leading-loose);
    margin-bottom: var(--space-xs);
  }

  /* Cover image — full width, rounded, sits between the header and the body */
  .post-cover {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: var(--space-2xl);
    display: block;
  }

  /* Images — full width, rounded corners, breathing room above and below */
  .post-body img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-top: var(--space-xl);
    display: block;
  }

  /* Caption — the italic <em> text that follows each image or video.
     Uses the UI text style: --text-xs + letter-spacing + slate color.
     The selector matches a paragraph containing only an <em> that comes
     right after an <img> or after any element (for video captions). */
  .post-body img + p > em:only-child,
  .post-body video + p > em:only-child {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-slate);
    letter-spacing: 0.08em;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-xl);
    line-height: var(--leading-relaxed);
  }
</style>
