---
// Button.astro — Reusable button / link component
// Two visual variants: "primary" (navy filled) and "secondary" (surface outlined).
// When an `href` prop is provided, this renders as an <a> tag (a link that navigates).
// Without `href`, it renders as a <button> (an action element like a form submit).
// This distinction matters for accessibility — screen readers announce them differently.

// Destructure our props with default values:
//   label    — the visible text inside the button
//   href     — optional URL; if present, renders as <a>
//   variant  — "primary" or "secondary" (defaults to "primary")
//   download — adds the HTML `download` attribute, triggering a file save instead of navigation
//   disabled — greys out the button and prevents interaction
//   icon     — optional SVG string rendered on the LEFT of the label.
//              When provided, the right-side arrow is hidden and the icon appears instead.
//              Pass a raw SVG string, e.g. icon='<svg ...>...</svg>'
const { label, href, variant = 'primary', download = false, disabled = false, icon } = Astro.props;
---

<!--
  Conditional rendering: Astro's {condition ? A : B} syntax lets us output
  different HTML based on whether `href` was passed in.

  The SVG arrow inside each button is the same path — a simple → right arrow.
  CSS rotates it -45deg at rest (pointing ↗) and 0deg on hover (pointing →).
-->

<style>
  /*
    WHY STYLES ARE HERE AND NOT IN global.css:
    Something in the Tailwind/shadcn base layer generates a rule that overrides
    .btn--secondary:hover in global.css regardless of specificity.

    Astro's scoped styles are the solution: Astro adds a unique data attribute
    (like data-astro-cid-abc123) to every element this component renders, then
    injects that attribute into these CSS selectors automatically. The result is
    a selector like `.btn--secondary:hover[data-astro-cid-abc123]` which has
    higher specificity than any plain class-based rule in global.css or Tailwind.

    .cls-... (scoped) = guaranteed to win over global CSS for THIS component's elements.
  */

  /* Light mode hover — background tints navy, border and text shift to navy.
     rgba(8, 31, 93, ...) = --color-navy (#081F5D) as an rgba value.
     We use rgba here (not the token) because CSS can't do var(--color-navy) at 5% opacity
     directly — the same pattern already used for the dark mode glass tints below.
     !important on border-color and color: Tailwind/shadcn's @layer base injects a
     border-color rule that wins even over Astro's scoped attribute selector. */
  .btn--secondary:hover {
    background-color: rgba(8, 31, 93, 0.05) !important; /* navy at 5% — subtle tint */
    border-color: var(--color-navy) !important;
    color: var(--color-navy) !important;
  }

  /* Dark mode hover — border and text lighten to near-white.
     :global() tells Astro: don't scope [data-theme="dark"] (it lives on <html>),
     but DO scope .btn--secondary:hover (it lives on the button element). */
  :global([data-theme="dark"]) .btn--secondary:hover {
    background-color: rgba(160, 175, 181, 0.2) !important;
    border-color: var(--color-heading) !important;
    color: var(--color-heading) !important;
  }
</style>

{href ? (
  <a
    href={disabled ? undefined : href}
    class={`btn btn--${variant}${disabled ? ' btn--disabled' : ''}`}
    download={download ? true : undefined}
    aria-disabled={disabled ? 'true' : undefined}
    tabindex={disabled ? -1 : undefined}
  >
    {/* If an icon was passed: render it on the left and skip the arrow */}
    {icon
      ? <Fragment set:html={`<span class="btn-icon-left" aria-hidden="true">${icon}</span>`} />
      : null
    }
    {label}
    {/* Only show the arrow when there is no left icon */}
    {!icon &&
      <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M2 8H14M9 3L14 8L9 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    }
  </a>
) : (
  <button
    class={`btn btn--${variant}${disabled ? ' btn--disabled' : ''}`}
    disabled={disabled ? true : undefined}
  >
    {/* If an icon was passed: render it on the left and skip the arrow */}
    {icon
      ? <Fragment set:html={`<span class="btn-icon-left" aria-hidden="true">${icon}</span>`} />
      : null
    }
    {label}
    {/* Only show the arrow when there is no left icon */}
    {!icon &&
      <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M2 8H14M9 3L14 8L9 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    }
  </button>
)}
