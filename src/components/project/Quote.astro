---
// Quote.astro — Pullquote component for project pages.
//
// Three variants, matching the Framer portfolio design:
//
//   variant="dark"      Navy background, cream italic text, attribution below.
//                       Used for: opening hero testimonials.
//
//   variant="light"     Light blue (Navy 100) background, navy italic text.
//                       Used for: mid-page user research quotes.
//
//   variant="takeaway"  No background. Optional eyebrow label above ("My takeaway:").
//                       Royal blue italic text. No attribution.
//                       Used for: designer's own synthesis/reflection quotes.
//
// Usage in MDX:
//   import Quote from '../../components/project/Quote.astro';
//
//   <Quote
//     variant="dark"
//     text="Finally, a magnifier that's reliable, private, and doesn't drain my battery."
//     attribution="Trusted Tester Testimonial, User with Low-Vision"
//   />
//
//   <Quote
//     variant="takeaway"
//     eyebrow="My takeaway:"
//     text="Magnifiers and cameras are not reliable companions during users' most stressful, on-the-go moments."
//   />

interface Props {
  text:          string;              // The quote text — include your own curly quotes in the string
  attribution?:  string;              // Source line (dark + light variants only)
  eyebrow?:      string;              // Small label above (takeaway variant only), e.g. "My takeaway:"
  variant?:      'dark' | 'light' | 'takeaway'; // defaults to 'dark'
}

const {
  text,
  attribution,
  eyebrow,
  variant = 'dark',
} = Astro.props;
---

<!-- data-reveal is added to dark variant quotes so the scroll animation
     targets only those — light and takeaway variants are unaffected. -->
<figure class="pq-quote" data-variant={variant} data-reveal={variant === 'dark' ? 'quote' : undefined}>

  {/* Eyebrow label — only for takeaway variant */}
  {eyebrow && (
    <p class="pq-eyebrow">{eyebrow}</p>
  )}

  {/* The quote text — Fraunces italic, large display size */}
  <blockquote class="pq-text">{text}</blockquote>

  {/* Attribution — only for dark + light variants */}
  {attribution && (
    <figcaption class="pq-attribution">{attribution}</figcaption>
  )}

</figure>


<style>
  /* ── Shared wrapper ─────────────────────────────────────────────────────── */

  .pq-quote {
    margin: var(--space-3xl) 0;
    padding: var(--space-3xl) var(--space-2xl);
    border-radius: 4px;

    /* CSS custom properties let each variant override just what it needs.
       These are the defaults — used by the takeaway variant. */
    --pq-bg:          transparent;
    --pq-text-color:  var(--color-royal-blue);
    --pq-attr-color:  var(--color-charcoal);
    --pq-text-size:   var(--text-3xl);

    background-color: var(--pq-bg);
  }


  /* ── Dark variant ───────────────────────────────────────────────────────── */
  /* Full-bleed banner treatment: negative margins cancel the container's
     padding-inline so the navy background stretches edge-to-edge.
     min-height + flex centering give it a consistent section-like height.
     navy-100 (#C0D4F4) for the attribution — the lightest brand ramp step,
     reads as a cool tertiary on the navy background without introducing a new color. */

  .pq-quote[data-variant="dark"] {
    --pq-bg:          var(--color-navy);
    --pq-text-color:  hsl(216 60% 94%);       /* warm near-white — softer than pure white */
    --pq-attr-color:  hsl(var(--navy-100));   /* #C0D4F4 — ~7:1 contrast on navy, passes WCAG AA */
    --pq-text-size:   var(--text-3xl);

    /* True full-bleed: calc(50% - 50vw) pushes left edge to viewport edge
       regardless of any container max-width. 100vw fills the full viewport width.
       This is different from negative-margin which only cancels container padding. */
    margin-inline: calc(50% - 50vw);
    width: 100vw;
    border-radius: 0;

    /* Vertical rhythm — generous top/bottom for section presence.
       Horizontal: max() picks the larger of the two values.
       On wide screens calc(50% - 430px) wins — centers text at 860px wide.
       On narrow screens var(--space-xl) wins — keeps normal breathing room. */
    padding-block: var(--space-4xl);
    /* Aligns text with the content inside .project-container.
       The container is max 860px centered, with 32px (--space-xl) of inner padding.
       Content left edge = (viewport - 860) / 2 + 32 = 50vw - 430px + 32px = 50vw - 398px.
       max() falls back to --space-xl when the viewport is narrower than 860px. */
    padding-inline: max(var(--space-xl), calc(50vw - 398px));

    /* Taller min-height so the section has real presence */
    min-height: clamp(400px, 50vh, 600px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }


  /* ── Light variant ──────────────────────────────────────────────────────── */
  /* Navy-100 background (#C0D4F4). Dark navy text. */

  .pq-quote[data-variant="light"] {
    --pq-bg:          hsl(var(--secondary)); /* Navy 100 — same token used for light bg surfaces */
    --pq-text-color:  var(--color-navy);
    --pq-attr-color:  var(--color-charcoal);
    --pq-text-size:   var(--text-3xl);
  }


  /* ── Takeaway variant ───────────────────────────────────────────────────── */
  /* No background, less padding, slightly smaller text. */

  .pq-quote[data-variant="takeaway"] {
    --pq-text-color:  var(--color-royal-blue);
    --pq-text-size:   var(--text-2xl);
    padding-left: 0;
    padding-right: 0;
  }


  /* ── Eyebrow ────────────────────────────────────────────────────────────── */
  /* Small label above the quote text ("My takeaway:") */

  .pq-eyebrow {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-charcoal);
    margin-bottom: var(--space-md);
    /* Not italic — acts as a structural label above the display text */
  }


  /* ── Quote text ─────────────────────────────────────────────────────────── */
  /* Fraunces italic — the display font at a large size.
     margin: 0 removes the browser's default blockquote indentation. */

  .pq-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-regular); /* Regular italic — not bold italic */
    font-size: var(--pq-text-size);
    line-height: var(--leading-tight);
    color: var(--pq-text-color);
    margin: 0;
    padding: 0; /* Remove browser default blockquote padding/border */
    border: none;
    background: none;
  }


  /* ── Attribution ────────────────────────────────────────────────────────── */

  .pq-attribution {
    margin-top: var(--space-lg);
    font-size: var(--text-base); /* 16px — WCAG AA requires larger text for lower contrast ratios */
    color: var(--pq-attr-color);
    font-style: normal; /* Not italic — grounded contrast to the quote above */
    line-height: var(--leading-normal);
  }


  /* ── Scroll reveal — initial hidden state ───────────────────────────────── */
  /* Dark variant quotes start invisible and shifted down 24px.
     The IntersectionObserver below adds .pq-revealed when the quote
     enters the viewport, triggering the transition.
     prefers-reduced-motion: skip the transform, just fade. */

  [data-reveal="quote"] .pq-text,
  [data-reveal="quote"] .pq-attribution {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.9s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.9s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Attribution cascades in 0.2s after the quote text */
  [data-reveal="quote"] .pq-attribution {
    transition-delay: 0.2s;
  }

  /* Revealed state — added by IntersectionObserver */
  [data-reveal="quote"].pq-revealed .pq-text,
  [data-reveal="quote"].pq-revealed .pq-attribution {
    opacity: 1;
    transform: translateY(0);
  }

  /* Respect reduced motion — fade only, no movement */
  @media (prefers-reduced-motion: reduce) {
    [data-reveal="quote"] .pq-text,
    [data-reveal="quote"] .pq-attribution {
      transform: none;
      transition: opacity 0.5s ease;
    }
  }


  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  /* Scale the text down on narrow screens so long quotes don't overflow. */

  @media (max-width: 600px) {
    .pq-quote {
      --pq-text-size: var(--text-2xl);
      padding: var(--space-2xl) var(--space-lg);
    }

    .pq-quote[data-variant="dark"] {
      padding: var(--space-3xl) var(--space-lg);
    }

    .pq-quote[data-variant="takeaway"] {
      --pq-text-size: var(--text-xl);
      padding-left: 0;
      padding-right: 0;
    }
  }
</style>


<script>
  // Scroll reveal for dark variant Quote blocks.
  //
  // IntersectionObserver fires when an element enters the viewport.
  // threshold: 0.2 means 20% of the element must be visible before
  // the animation triggers — gives the reader time to notice they're
  // arriving at the quote before the text starts moving.
  //
  // Once revealed, the observer disconnects from that element so the
  // animation only plays once (not every time it scrolls in and out).

  const quotes = document.querySelectorAll('[data-reveal="quote"]');

  if (quotes.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('pq-revealed');
            observer.unobserve(entry.target); // play once only
          }
        });
      },
      { threshold: 0.2 }
    );

    quotes.forEach((quote) => observer.observe(quote));
  }
</script>
