---
// [slug].astro — Individual post page
// The filename [slug] is a special Astro convention meaning "dynamic route".
// Astro will generate one page per post, e.g. /writing/learning-in-public
// getStaticPaths() tells Astro which slugs exist at build time.

import { getCollection, render } from 'astro:content';
import '../../styles/global.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import BasisButton from '@/components/ui/forms/Button.astro';

// getStaticPaths runs once at build time and returns one entry per post.
// Each entry becomes a separate page URL.
export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

// props.post is the individual post data passed from getStaticPaths above.
const { post } = Astro.props;

// render() converts the Markdown body into HTML.
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Marco Lobato`}>

  <!-- x-data holds lightbox state: open/closed, current image src, current caption.
       @open-lightbox.window listens for the custom event fired by the script below.
       @keydown.escape.window lets the user press Escape to close. -->
  <div
    x-data="{ open: false, src: '', caption: '' }"
    @open-lightbox.window="open = true; src = $event.detail.src; caption = $event.detail.caption"
    @keydown.escape.window="open = false"
  >

    <!-- Lightbox overlay — dark backdrop, tap outside or press Escape to close -->
    <div
      class="lightbox-overlay"
      x-show="open"
      x-transition
      style="display: none;"
      @click.self="open = false"
    >
      <div class="lightbox-inner">
        <!-- Close button — Basis UI ghost/icon button with an X icon -->
        <BasisButton variant="ghost" size="icon" className="lightbox-close" @click="open = false" aria-label="Close image">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </BasisButton>
        <!-- The enlarged image -->
        <img class="lightbox-img" :src="src" :alt="caption" />
        <!-- Caption — only shown if the image has one -->
        <p class="lightbox-caption" x-show="caption" x-text="caption"></p>
      </div>
    </div>

    <Nav />

    <main class="post-main">
      <div class="post-container">

        <!-- Back link to the Field Notes archive at /experiments.
             "All field notes" (not just "Field Notes") matches the homepage
             "View all field notes" button and disambiguates from the homepage
             section's nav anchor (/#field-notes). -->
        <a href="/experiments" class="post-back">← All field notes</a>

        <!-- Post header -->
        <header class="post-header">
          <p class="post-date">
            <!-- "Marco Lobato · May 14, 2025" — name + middle dot + formatted date -->
            Marco Lobato · {post.data.date.toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <h1 class="post-title">{post.data.title}</h1>
        </header>

        <!-- Cover image — shown if the post's frontmatter includes an `image` field -->
        {post.data.image && (
          <img src={post.data.image} alt={post.data.title} class="post-cover" />
        )}

        <!-- Post body — Content is the rendered Markdown from the .md file -->
        <div class="post-body">
          <Content />
        </div>

      </div>
    </main>

  </div>

</BaseLayout>

<script>
  // Make every image in the post body open the lightbox when clicked or tapped.
  // We fire a custom event that Alpine picks up via @open-lightbox.window above.
  document.querySelectorAll<HTMLImageElement>('.post-body img').forEach(img => {
    img.addEventListener('click', () => {
      // Image and caption share the same <p> (no blank line between them in markdown).
      // The <em> caption is the direct next sibling of <img> inside that paragraph.
      const nextEl = img.nextElementSibling;
      const caption = nextEl?.tagName === 'EM' ? nextEl.textContent ?? '' : '';
      window.dispatchEvent(new CustomEvent('open-lightbox', {
        detail: { src: img.src, caption }
      }));
    });
  });
</script>


<style>
  /* Nav styles live in src/components/Nav.astro */

  .post-main {
    padding-block: var(--space-3xl);
  }

  .post-container {
    max-width: 680px; /* narrower than the site container — ideal for long-form reading */
    margin-inline: auto;
    padding-inline: var(--space-xl);
  }

  .post-back {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-royal-blue);
    margin-bottom: var(--space-2xl);
    transition: color 0.2s ease;
  }
  /* WCAG 1.4.1: underline is the non-color hover cue.
     --color-heading flips automatically: navy in light, near-white in dark. */
  .post-back:hover {
    color: var(--color-heading);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-slate);
  }

  .post-date {
    font-size: var(--text-sm);
    /* --color-charcoal gives 12:1 contrast on white in light mode, and
       auto-flips to #B0BFCC (8:1) on the dark navy background in dark mode.
       --color-slate was 2.24:1 on white — too low to pass WCAG AA. */
    color: var(--color-charcoal);
    margin-bottom: var(--space-sm);
    max-width: none;
  }

  .post-title {
    /* h1 from global.css */
    margin-bottom: var(--space-md);
  }

  .post-description {
    font-size: var(--text-lg);
    color: var(--color-charcoal);
    margin-bottom: 0;
  }

  /* Post body — styles the rendered Markdown content */
  /* :global() is required here — h2, h3, p come from rendered markdown via
     <Content /> and don't receive Astro's scope attribute, so scoped selectors
     like .post-body h2 would never match them. Same reason links/lists use :global(). */
  :global(.post-body h2) { margin-top: var(--space-2xl); margin-bottom: var(--space-xl); }
  :global(.post-body h3) { margin-top: var(--space-xl);  margin-bottom: var(--space-lg); }
  :global(.post-body p)  { line-height: var(--leading-loose); }

  /* Links — mirrors the .text-link component from the design system.
     :global() is needed because <a> tags come from rendered markdown
     and don't receive Astro's scope attribute. */
  /* WCAG 1.4.1: underline must always be visible — color alone is not enough.
     Royal blue + underline at rest; heading color on hover adds a second cue. */
  :global(.post-body a) {
    color: var(--color-royal-blue);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }
  :global(.post-body a:hover) {
    color: var(--color-heading);
  }

  /* Restore bullets and numbers — the global reset strips these from all lists.
     :global() is required here because <ul> and <li> come from rendered markdown
     via <Content />, so they don't receive Astro's scope attribute. Without
     :global(), the scoped selector won't match those elements. */
  :global(.post-body ul) {
    list-style: disc;
    padding-left: var(--space-xl);
    margin-bottom: var(--space-md);
  }
  :global(.post-body ol) {
    list-style: decimal;
    padding-left: var(--space-xl);
    margin-bottom: var(--space-md);
  }
  :global(.post-body li) {
    line-height: var(--leading-loose);
    margin-bottom: var(--space-xs);
  }

  /* Cover image — full width, rounded, sits between the header and the body */
  .post-cover {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: var(--space-2xl);
    display: block;
  }

  /* Images — full width, rounded corners, breathing room above and below.
     cursor: zoom-in hints that the image is tappable to open the lightbox. */
  .post-body img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-top: var(--space-xl);
    display: block;
    cursor: zoom-in;
  }

  /* Lightbox overlay — fixed full-screen dark backdrop */
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: rgba(8, 31, 93, 0.93); /* deep navy at high opacity */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
  }

  /* Inner container — holds the close button, image, and caption */
  .lightbox-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    max-width: min(94vw, 1200px);
  }

  /* The enlarged image — constrained to viewport, natural aspect ratio */
  .lightbox-img {
    max-width: 100%;
    max-height: 88vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
    display: block;
    cursor: default;
  }

  /* Close button — top-right corner of the inner container.
     Default white so the X is visible on the dark navy backdrop.
     On hover, the ghost button supplies the yellow box naturally —
     we just flip the icon to dark so it reads against it. */
  .lightbox-close {
    position: absolute;
    top: -48px;
    right: -8px;
    color: white;
  }
  .lightbox-close:hover {
    color: black !important;
  }

  /* Caption text below the lightbox image */
  .lightbox-caption {
    color: white;
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-align: center;
    line-height: var(--leading-relaxed);
    max-width: 60ch;
  }

  /* Caption — the italic <em> that follows an image in the same paragraph.
     Remark puts image and caption in the same <p> when there's no blank line
     between them, so the <em> is a direct sibling of <img>, not a child of
     a separate <p>. :global() is required because <img> and <em> come from
     rendered markdown and don't receive Astro's scope attribute. */
  :global(.post-body img + em) {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-slate);
    letter-spacing: 0.08em;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-xl);
    line-height: var(--leading-relaxed);
  }
</style>
