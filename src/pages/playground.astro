---
// styleguide.astro — Marco Lobato Design System
// This page is both documentation and a live exhibit.
// Every color, type style, and component shown here is the real thing —
// built with the same tokens and global styles used across the whole site.
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionLabel from '../components/SectionLabel.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Button from '../components/Button.astro';
import BasisButton from '@/components/ui/forms/Button.astro';
import Badge from '@/components/ui/feedback/Badge.astro';
import Card from '@/components/ui/display/card/Card.astro';
import CardHeader from '@/components/ui/display/card/CardHeader.astro';
import CardContent from '@/components/ui/display/card/CardContent.astro';
import CardFooter from '@/components/ui/display/card/CardFooter.astro';
import Divider from '@/components/ui/layout/Divider.astro';
import BasisText from '@/components/ui/display/Text.astro';
import BasisNavbar from '@/components/ui/display/Navbar.astro';
---

<BaseLayout title="Playground — Marco Lobato">

    <!-- Sticky wrapper — on mobile both bars stick together as a unit.
         Wrapping them in a single element is more reliable than two sibling sticky elements. -->
    <div class="pg-nav-wrapper">
    <Nav />

    <!-- Mobile secondary nav bar — lives inside the sticky wrapper so it always stays
         anchored below the site nav. The button dispatches a plain window event;
         the Alpine scope below listens for it via @toggle-sidebar.window. -->
    <div class="pg-mobile-nav-bar">
      <BasisButton
        variant="ghost"
        size="icon"
        className="pg-mobile-nav-trigger"
        onclick="window.dispatchEvent(new CustomEvent('toggle-sidebar'))"
        aria-label="Toggle navigation"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <path d="M9 3v18"/>
        </svg>
      </BasisButton>
      <span class="pg-mobile-nav-title">Playground</span>
    </div>
    </div><!-- /.pg-nav-wrapper -->

    <!-- Alpine.js scope — tracks whether the sidebar is open.
         Starts open on desktop (≥1200px) and closed on mobile.
         Listens for toggle-sidebar (from mobile nav bar), close-sidebar, and Escape. -->
    <div x-data="{ open: window.innerWidth >= 1200 }" @keydown.escape.window="open = false" @close-sidebar.window="open = false" @toggle-sidebar.window="open = !open">

    <!-- Backdrop — mobile only. CSS hides it on desktop via display:none !important. -->
    <div class="pg-backdrop" x-show="open" @click="open = false" x-transition style="display: none;"></div>

    <div class="pg-layout">

      <!-- ===================================================================
           SIDEBAR NAVIGATION
           Tree-style nav inspired by Storybook. Group labels are non-linked
           headers. Links jump to sections; sub-links jump to individual
           components within a section.
           =================================================================== -->
      <!-- Desktop ≥1200px: closed = 40px rail (expand button only, no occlusion).
           Desktop 769–1199px: closed = fully hidden (translateX -100%).
           Mobile: open = slides in as drawer. -->
      <aside class="pg-sidebar" :class="{ 'pg-sidebar--closed': !open, 'pg-sidebar--open': open }">

        <!-- Expand button — visible only in rail mode (closed, ≥1200px). Centered in the 40px strip. -->
        <BasisButton variant="ghost" size="icon" className="pg-sidebar-expand-btn" @click="open = true" aria-label="Open navigation">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <path d="M9 3v18"/>
          </svg>
        </BasisButton>

        <!-- Close button row — visible when sidebar is fully open. Right-aligned. -->
        <div class="pg-sidebar-header">
          <BasisButton variant="ghost" size="icon" className="pg-sidebar-close-btn" @click="open = false" aria-label="Close navigation">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m15 18-6-6 6-6"/>
            </svg>
          </BasisButton>
        </div>

        <!-- Nav links — hidden in rail mode, shown when fully open -->
        <nav class="pg-sidebar-nav" aria-label="Design system navigation">

          <div class="pg-sidebar-group">
            <p class="pg-sidebar-group-label">Design Tokens</p>
            <!-- Only close the drawer on mobile — on desktop the sidebar stays open -->
            <a href="#color-palette" class="pg-sidebar-link" @click="if (window.innerWidth < 769) open = false">Color Palette</a>
            <a href="#typography" class="pg-sidebar-link" @click="if (window.innerWidth < 769) open = false">Typography</a>
          </div>

          <div class="pg-sidebar-group">
            <p class="pg-sidebar-group-label">Basis UI</p>
            <a href="#basis-ui-components" class="pg-sidebar-link" @click="if (window.innerWidth < 769) open = false">Overview</a>
            <a href="#basis-button" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Button</a>
            <a href="#basis-text" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Text</a>
            <a href="#basis-card" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Card</a>
            <a href="#basis-divider" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Divider</a>
            <a href="#basis-navbar" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Navbar</a>
            <a href="#basis-badge" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Badge</a>
          </div>

          <div class="pg-sidebar-group">
            <p class="pg-sidebar-group-label">Astro Components</p>
            <a href="#astro-components" class="pg-sidebar-link" @click="if (window.innerWidth < 769) open = false">Overview</a>
            <a href="#astro-button" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Button</a>
            <a href="#astro-text-link" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Text Link</a>
            <a href="#astro-section-label" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Section Label</a>
            <a href="#astro-navigation" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Navigation</a>
            <a href="#astro-project-card" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Project Card</a>
            <a href="#astro-theme-toggle" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Theme Toggle</a>
            <a href="#astro-carousel" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Carousel</a>
            <a href="#astro-footer" class="pg-sidebar-sublink" @click="if (window.innerWidth < 769) open = false">Footer</a>
          </div>

        </nav><!-- /.pg-sidebar-nav -->

      </aside>


      <main class="sg-main">

      <!-- ===================================================================
           PAGE HEADER
           =================================================================== -->
      <header class="sg-header">

        <!-- Panel icon toggle — desktop only. Hidden on mobile; pg-mobile-nav-bar handles mobile. -->
        <BasisButton
          variant="ghost"
          size="icon"
          className="pg-sidebar-toggle"
          @click="open = !open"
          :aria-expanded="open ? 'true' : 'false'"
          aria-label="Toggle navigation"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <path d="M9 3v18"/>
          </svg>
        </BasisButton>

        <p class="section-label">Living Document</p>
        <h1>Design System</h1>
        <div class="sg-header-sections">
          <div class="sg-header-section">
            <p class="sg-header-section-title">Design System</p>
            <p class="sg-header-desc">Everything I built to make this site. Colors, type, and components — shown as-is, no abstractions.</p>
          </div>
        </div>
      </header>


      <!-- ===================================================================
           SECTION: COLOR PALETTE
           =================================================================== -->
      <section class="sg-section" id="color-palette">
        <h2 class="sg-section-title">Color Palette</h2>
        <p class="sg-section-desc">
          The full palette — semantic tokens for UI, and the brand ramps they're built from.
          All values are CSS custom properties in <code>global.css</code> using HSL.
        </p>


        <!-- ── Theme colors ─────────────────────────────────────────────── -->
        <h3 class="sg-subsection-title">Theme colors</h3>
        <p class="sg-section-desc" style="margin-bottom: var(--space-lg);">
          Each card shows a background color with its paired foreground color
          as text — so you can immediately judge contrast. These are the tokens
          Basis UI components read directly.
        </p>

        <div class="sg-color-pairs">

          <!-- background / foreground -->
          <div class="sg-color-pair">
            <div class="sg-color-pair-swatch" style="background: hsl(var(--background)); border-bottom: 1px solid hsl(var(--border));">
              <span class="sg-color-pair-sample" style="color: hsl(var(--foreground));">Aa</span>
            </div>
            <div class="sg-color-pair-meta">
              <p class="sg-color-pair-name">Background</p>
              <code class="sg-color-pair-token">--background</code>
              <code class="sg-color-pair-token">--foreground</code>
            </div>
          </div>

          <!-- card / card-foreground -->
          <div class="sg-color-pair">
            <div class="sg-color-pair-swatch" style="background: hsl(var(--card)); border-bottom: 1px solid hsl(var(--border));">
              <span class="sg-color-pair-sample" style="color: hsl(var(--card-foreground));">Aa</span>
            </div>
            <div class="sg-color-pair-meta">
              <p class="sg-color-pair-name">Card</p>
              <code class="sg-color-pair-token">--card</code>
              <code class="sg-color-pair-token">--card-foreground</code>
            </div>
          </div>

          <!-- popover / popover-foreground -->
          <div class="sg-color-pair">
            <div class="sg-color-pair-swatch" style="background: hsl(var(--popover)); border-bottom: 1px solid hsl(var(--border));">
              <span class="sg-color-pair-sample" style="color: hsl(var(--popover-foreground));">Aa</span>
            </div>
            <div class="sg-color-pair-meta">
              <p class="sg-color-pair-name">Popover</p>
              <code class="sg-color-pair-token">--popover</code>
              <code class="sg-color-pair-token">--popover-foreground</code>
            </div>
          </div>

          <!-- primary / primary-foreground -->
          <div class="sg-color-pair">
            <div class="sg-color-pair-swatch" style="background: hsl(var(--primary));">
              <span class="sg-color-pair-sample" style="color: hsl(var(--primary-foreground));">Aa</span>
            </div>
            <div class="sg-color-pair-meta">
              <p class="sg-color-pair-name">Primary</p>
              <code class="sg-color-pair-token">--primary</code>
              <code class="sg-color-pair-token">--primary-foreground</code>
            </div>
          </div>

          <!-- secondary / secondary-foreground -->
          <div class="sg-color-pair">
            <div class="sg-color-pair-swatch" style="background: hsl(var(--secondary));">
              <span class="sg-color-pair-sample" style="color: hsl(var(--secondary-foreground));">Aa</span>
            </div>
            <div class="sg-color-pair-meta">
              <p class="sg-color-pair-name">Secondary</p>
              <code class="sg-color-pair-token">--secondary</code>
              <code class="sg-color-pair-token">--secondary-foreground</code>
            </div>
          </div>

          <!-- accent / accent-foreground -->
          <div class="sg-color-pair">
            <div class="sg-color-pair-swatch" style="background: hsl(var(--accent));">
              <span class="sg-color-pair-sample" style="color: hsl(var(--accent-foreground));">Aa</span>
            </div>
            <div class="sg-color-pair-meta">
              <p class="sg-color-pair-name">Accent</p>
              <code class="sg-color-pair-token">--accent</code>
              <code class="sg-color-pair-token">--accent-foreground</code>
            </div>
          </div>

          <!-- muted / muted-foreground -->
          <div class="sg-color-pair">
            <div class="sg-color-pair-swatch" style="background: hsl(var(--muted));">
              <span class="sg-color-pair-sample" style="color: hsl(var(--muted-foreground));">Aa</span>
            </div>
            <div class="sg-color-pair-meta">
              <p class="sg-color-pair-name">Muted</p>
              <code class="sg-color-pair-token">--muted</code>
              <code class="sg-color-pair-token">--muted-foreground</code>
            </div>
          </div>

          <!-- destructive / destructive-foreground -->
          <div class="sg-color-pair">
            <div class="sg-color-pair-swatch" style="background: hsl(var(--destructive));">
              <span class="sg-color-pair-sample" style="color: hsl(var(--destructive-foreground));">Aa</span>
            </div>
            <div class="sg-color-pair-meta">
              <p class="sg-color-pair-name">Destructive</p>
              <code class="sg-color-pair-token">--destructive</code>
              <code class="sg-color-pair-token">--destructive-foreground</code>
            </div>
          </div>

        </div>


        <!-- ── UI colors ────────────────────────────────────────────────── -->
        <h3 class="sg-subsection-title">UI colors</h3>
        <p class="sg-section-desc" style="margin-bottom: var(--space-lg);">
          Single-use tokens for structural UI elements — not surfaces or text,
          but borders, inputs, and focus rings.
        </p>

        <div class="sg-swatches">

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background: hsl(var(--border)); border: 1px solid hsl(var(--muted-foreground) / 30%);"></div>
            <p class="sg-swatch-name">Border</p>
            <code class="sg-swatch-token">--border</code>
            <p class="sg-swatch-use">Card edges, dividers</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background: hsl(var(--input)); border: 1px solid hsl(var(--muted-foreground) / 30%);"></div>
            <p class="sg-swatch-name">Input</p>
            <code class="sg-swatch-token">--input</code>
            <p class="sg-swatch-use">Form field borders</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background: hsl(var(--ring));"></div>
            <p class="sg-swatch-name">Ring</p>
            <code class="sg-swatch-token">--ring</code>
            <p class="sg-swatch-use">Focus ring — Navy 700</p>
          </div>

        </div>


        <!-- ── Brand ramp — Navy ────────────────────────────────────────── -->
        <h3 class="sg-subsection-title">Brand ramp — Navy</h3>
        <div class="sg-ramp">
          <div class="sg-ramp-stop" style="background: hsl(var(--navy-900));">
            <span class="sg-ramp-stop-name" style="color: #fff;">900</span>
            <span class="sg-ramp-stop-hex" style="color: #fff;">#081F5D</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(var(--navy-800));">
            <span class="sg-ramp-stop-name" style="color: #fff;">800</span>
            <span class="sg-ramp-stop-hex" style="color: #fff;">#0A2872</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(var(--navy-700));">
            <span class="sg-ramp-stop-name" style="color: #fff;">700</span>
            <span class="sg-ramp-stop-hex" style="color: #fff;">#1040A8</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(var(--navy-500));">
            <span class="sg-ramp-stop-name" style="color: #fff;">500</span>
            <span class="sg-ramp-stop-hex" style="color: #fff;">#2060D0</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(var(--navy-300));">
            <span class="sg-ramp-stop-name" style="color: #081F5D;">300</span>
            <span class="sg-ramp-stop-hex" style="color: #081F5D;">#6090E0</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(var(--navy-100));">
            <span class="sg-ramp-stop-name" style="color: #081F5D;">100</span>
            <span class="sg-ramp-stop-hex" style="color: #081F5D;">#C0D4F4</span>
          </div>
        </div>


        <!-- ── Brand ramp — Lemon ───────────────────────────────────────── -->
        <h3 class="sg-subsection-title">Brand ramp — Lemon</h3>
        <div class="sg-ramp">
          <div class="sg-ramp-stop" style="background: hsl(var(--lemon-900));">
            <span class="sg-ramp-stop-name" style="color: #fff;">900</span>
            <span class="sg-ramp-stop-hex" style="color: #fff;">#8A8A0A</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(var(--lemon-700));">
            <span class="sg-ramp-stop-name" style="color: #fff;">700</span>
            <span class="sg-ramp-stop-hex" style="color: #fff;">#BFBF12</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(var(--lemon-500));">
            <span class="sg-ramp-stop-name" style="color: #8A8A0A;">500</span>
            <span class="sg-ramp-stop-hex" style="color: #8A8A0A;">#F1F11C</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(var(--lemon-300));">
            <span class="sg-ramp-stop-name" style="color: #8A8A0A;">300</span>
            <span class="sg-ramp-stop-hex" style="color: #8A8A0A;">#F6F670</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(var(--lemon-100));">
            <span class="sg-ramp-stop-name" style="color: #8A8A0A;">100</span>
            <span class="sg-ramp-stop-hex" style="color: #8A8A0A;">#FAFABC</span>
          </div>
        </div>


        <!-- ── Neutral scale ────────────────────────────────────────────── -->
        <h3 class="sg-subsection-title">Neutral scale</h3>
        <div class="sg-ramp">
          <!-- Values inline because neutrals don't have --neutral-* ramp tokens;
               they map directly to semantic tokens (foreground, muted, border, etc.) -->
          <div class="sg-ramp-stop" style="background: hsl(0 0% 10.2%);">
            <span class="sg-ramp-stop-name" style="color: #fff;">950</span>
            <span class="sg-ramp-stop-hex" style="color: #fff;">#1A1A1A</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(0 0% 30.2%);">
            <span class="sg-ramp-stop-name" style="color: #fff;">800</span>
            <span class="sg-ramp-stop-hex" style="color: #fff;">#4D4D4D</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(0 0% 50.2%);">
            <span class="sg-ramp-stop-name" style="color: #fff;">500</span>
            <span class="sg-ramp-stop-hex" style="color: #fff;">#808080</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(0 0% 85.1%);">
            <span class="sg-ramp-stop-name" style="color: #1A1A1A;">200</span>
            <span class="sg-ramp-stop-hex" style="color: #1A1A1A;">#D9D9D9</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(0 0% 94.9%);">
            <span class="sg-ramp-stop-name" style="color: #1A1A1A;">100</span>
            <span class="sg-ramp-stop-hex" style="color: #1A1A1A;">#F2F2F2</span>
          </div>
          <div class="sg-ramp-stop" style="background: hsl(0 0% 100%); border: 1px solid hsl(var(--border));">
            <span class="sg-ramp-stop-name" style="color: #1A1A1A;">0</span>
            <span class="sg-ramp-stop-hex" style="color: #1A1A1A;">#FFFFFF</span>
          </div>
        </div>


        <!-- ── Component aliases ────────────────────────────────────────── -->
        <h3 class="sg-subsection-title">Component aliases</h3>
        <p class="sg-section-desc" style="margin-bottom: var(--space-lg);">
          The <code>--color-*</code> tokens are backward-compatible aliases used
          by the handbuilt components (Button, Nav, Footer, Carousel,
          SectionLabel). They sit on top of the semantic tokens above.
          <strong>Fixed</strong> aliases always resolve to the same value
          regardless of theme. <strong>Theme-aware</strong> aliases flip
          automatically — toggle dark mode above to see them change.
        </p>

        <!-- Group 1: Fixed aliases -->
        <p class="sg-color-group-label">Fixed — same in light and dark</p>
        <div class="sg-swatches" style="margin-bottom: var(--space-xl);">

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background: var(--color-navy);"></div>
            <p class="sg-swatch-name">Navy</p>
            <code class="sg-swatch-token">--color-navy</code>
            <p class="sg-swatch-use">Footer bg, code blocks, button hover<br>#081F5D → Navy 900</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background: var(--color-royal-blue);"></div>
            <p class="sg-swatch-name">Royal Blue</p>
            <code class="sg-swatch-token">--color-royal-blue</code>
            <p class="sg-swatch-use">Links, nav hover, hero title<br>#1040A8 → Navy 700</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background: var(--color-lemon); border: 1px solid hsl(var(--border));"></div>
            <p class="sg-swatch-name">Lemon</p>
            <code class="sg-swatch-token">--color-lemon</code>
            <p class="sg-swatch-use">SectionLabel bg, Footer name<br>#F1F11C → Lemon 500</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background: var(--color-citrine); border: 1px solid hsl(var(--border));"></div>
            <p class="sg-swatch-name">Citrine <em style="font-style: normal; font-size: 10px; color: var(--color-slate);">(unused)</em></p>
            <code class="sg-swatch-token">--color-citrine</code>
            <p class="sg-swatch-use">Defined but not used in any component<br>#BFBF12 → Lemon 700</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background: var(--color-slate);"></div>
            <p class="sg-swatch-name">Slate</p>
            <code class="sg-swatch-token">--color-slate</code>
            <p class="sg-swatch-use">Borders, placeholders, Footer links<br>#808080 → Neutral 500</p>
          </div>

        </div>

        <!-- Group 2: Theme-aware aliases -->
        <p class="sg-color-group-label">Theme-aware — flips with dark mode</p>
        <div class="sg-swatches">

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background: var(--color-heading); border: 1px solid hsl(var(--border));"></div>
            <p class="sg-swatch-name">Heading</p>
            <code class="sg-swatch-token">--color-heading</code>
            <p class="sg-swatch-use">h1–h6, nav name, carousel title<br>→ <code>--primary</code></p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background: var(--color-charcoal); border: 1px solid hsl(var(--border));"></div>
            <p class="sg-swatch-name">Charcoal</p>
