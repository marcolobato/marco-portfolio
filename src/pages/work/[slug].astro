---
// work/[slug].astro — Individual project page
//
// [slug] is a dynamic route — Astro generates one page per project file.
// e.g. src/content/projects/magnifier.mdx → /work/magnifier
//
// This mirrors the pattern used in writing/[slug].astro.
// getStaticPaths() runs once at build time and returns one entry per project.

import { getCollection, render } from 'astro:content';
import '../../styles/global.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import ProjectAccordion from '../../components/project/ProjectAccordion.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props:  { project },
  }));
}

const { project } = Astro.props;
const { data } = project;

// render() converts the MDX body into HTML, same as writing posts.
const { Content } = await render(project);
---

<BaseLayout title={`${data.title} — Marco Lobato`}>

  <Nav />

  <main class="project-main">
    <div class="project-container">

      <!-- ── Back link ────────────────────────────────────────────────────── -->
      <!-- Links back to the #work section on the home page, the same way
           writing posts link back to /#writing. -->
      <a href="/#work" class="project-back">← Work</a>

      <!-- ── Hero ─────────────────────────────────────────────────────────── -->
      <header class="project-hero">

        {data.heroImage && (
          <img
            src={data.heroImage}
            alt={data.title}
            class="project-hero-image"
          />
        )}

        <div class="project-hero-meta">
          <!-- "Made by Google" brand line, shown only if brand is set -->
          {data.brand && <p class="project-brand">{data.brand}</p>}
        </div>

        <h1 class="project-title">{data.title}</h1>

        <!-- App link button — only shown if appLink is set in frontmatter -->
        {data.appLink && (
          <a href={data.appLink} class="project-app-link" target="_blank" rel="noopener noreferrer">
            {data.appLinkLabel ?? 'View Project'}
            <!-- External link icon -->
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        )}

      </header>


      <!-- ── Project Overview ──────────────────────────────────────────────── -->
      <section class="project-overview">
        <h2 class="project-section-heading">Project Overview</h2>

        <div class="project-overview-grid">

          <div class="project-overview-item">
            <p class="project-overview-label">What it is</p>
            <p class="project-overview-body">{data.overview.what}</p>
          </div>

          <div class="project-overview-item">
            <p class="project-overview-label">Objective</p>
            <p class="project-overview-body">{data.overview.objective}</p>
          </div>

          <div class="project-overview-item">
            <p class="project-overview-label">What made it different</p>
            <p class="project-overview-body">{data.overview.differentiator}</p>
          </div>

        </div>
      </section>


      <!-- ── Contributions ─────────────────────────────────────────────────── -->
      <!-- ProjectAccordion renders the contributions array as an exclusive
           accordion: first item open by default, one open at a time.
           Items with empty content show as label-only rows (no chevron). -->
      <section class="project-contributions">
        <h2 class="project-section-heading">Contributions</h2>
        <ProjectAccordion contributions={data.contributions} />
      </section>


      <!-- ── MDX body ──────────────────────────────────────────────────────── -->
      <!-- Content is the rendered MDX from the project file's body.
           Narrative sections (quotes, user journeys, prototypes, reflection)
           all live here, written in the .mdx file. -->
      <div class="project-body">
        <Content />
      </div>


      <!-- ── Outcomes & Impact ─────────────────────────────────────────────── -->
      <section class="project-outcomes">
        <h2 class="project-section-heading">Outcomes & Impact</h2>

        <!-- Two-column layout: quote left, outcomes list right.
             If no outcomesQuote is set, the list spans full width. -->
        <div class={`project-outcomes-inner${data.outcomesQuote ? ' project-outcomes-inner--split' : ''}`}>

          {data.outcomesQuote && (
            <div class="project-outcomes-quote">
              <p class="project-outcomes-quote-text">{data.outcomesQuote.text}</p>
              <p class="project-outcomes-quote-attr">{data.outcomesQuote.attribution}</p>
            </div>
          )}

          <ul class="project-outcomes-list">
            {data.outcomes.map((item) => (
              <li class="project-outcome-item">
                <span class="project-outcome-emoji" aria-hidden="true">{item.emoji}</span>
                <span class="project-outcome-text">
                  <strong class="project-outcome-label">{item.label}</strong>
                  {' — '}{item.description}
                </span>
              </li>
            ))}
          </ul>

        </div>
      </section>


      <!-- ── Project Reflection ────────────────────────────────────────────── -->
      <!-- Only rendered when the reflection field is present in frontmatter.
           The && operator means "if data.reflection exists, render this block".
           The title is styled softly — smaller, lighter weight, not a bold UI heading.
           Paragraphs are split on \n\n so one string can produce multiple <p> tags. -->
      {data.reflection && (
        <section class="project-reflection">
          <p class="project-reflection-eyebrow">Project Reflection</p>
          <h2 class="project-reflection-title">{data.reflection.title}</h2>
          {data.reflection.body.split('\n\n').map((paragraph) => (
            <p class="project-reflection-body">{paragraph}</p>
          ))}
        </section>
      )}


    </div><!-- /.project-container -->
  </main>

</BaseLayout>


<style>
  /* ── Layout shell ─────────────────────────────────────────────────────── */

  .project-main {
    padding-block: var(--space-3xl);
  }

  /* Narrower than the site container — ideal for long-form reading.
     Same max-width used by writing posts. */
  .project-container {
    max-width: 720px;
    margin-inline: auto;
    padding-inline: var(--space-xl);
  }


  /* ── Back link ────────────────────────────────────────────────────────── */

  .project-back {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-royal-blue);
    margin-bottom: var(--space-2xl);
    transition: color 0.2s ease;
  }
  .project-back:hover { color: var(--color-navy); }


  /* ── Hero ─────────────────────────────────────────────────────────────── */

  .project-hero {
    margin-bottom: var(--space-3xl);
  }

  .project-hero-image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: var(--space-xl);
    display: block;
  }

  .project-hero-meta {
    margin-bottom: var(--space-sm);
  }

  /* "Made by Google" — small label above the title */
  .project-brand {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  /* h1 styles come from global.css */
  .project-title {
    margin-bottom: var(--space-lg);
  }

  /* App link — styled as a small outlined button */
  .project-app-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-royal-blue);
    border: 1px solid var(--color-royal-blue);
    border-radius: 4px;
    padding: var(--space-xs) var(--space-md);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .project-app-link:hover {
    background-color: var(--color-royal-blue);
    color: var(--color-white);
  }


  /* ── Shared section heading ───────────────────────────────────────────── */

  .project-section-heading {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-slate);
  }


  /* ── Project Overview ────────────────────────────────────────────────── */

  .project-overview {
    margin-bottom: var(--space-3xl);
  }

  /* Stack the three overview fields vertically with a divider between each */
  .project-overview-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .project-overview-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-charcoal);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  .project-overview-body {
    color: var(--color-charcoal);
    line-height: var(--leading-loose);
  }


  /* ── Contributions ───────────────────────────────────────────────────── */
  /* Layout only — accordion styles live in ProjectAccordion.astro */

  .project-contributions {
    margin-bottom: var(--space-3xl);
  }

  /* Tighten the gap between the "Contributions" heading and the first accordion
     row. The heading's border-bottom already acts as the visual divider, so
     the default margin-bottom is too generous here. */
  .project-contributions .project-section-heading {
    margin-bottom: 0;
  }


  /* ── MDX body ─────────────────────────────────────────────────────────── */

  .project-body {
    margin-bottom: var(--space-3xl);
  }

  /* These :global() rules style elements that come from the rendered MDX.
     Astro's scoped CSS doesn't reach inside <Content />, so :global() is
     required — same reason writing posts use it. */
  :global(.project-body h2) { margin-top: var(--space-2xl); margin-bottom: var(--space-xl); }
  :global(.project-body h3) { margin-top: var(--space-xl);  margin-bottom: var(--space-lg); }
  :global(.project-body p)  { line-height: var(--leading-loose); margin-bottom: var(--space-md); }

  /* Bullet and numbered lists — shared base styles */
  :global(.project-body ul),
  :global(.project-body ol) {
    padding-left: var(--space-xl);
    margin-bottom: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  :global(.project-body li) {
    line-height: var(--leading-loose);
    color: var(--color-charcoal);
    font-size: var(--text-base);
  }

  :global(.project-body a) {
    color: var(--color-royal-blue);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  :global(.project-body a:hover) {
    color: var(--color-navy);
    text-decoration: underline;
  }

  /* Blockquote — used for the pullquotes until Quote.astro is built in Phase 3 */
  :global(.project-body blockquote) {
    border-left: 3px solid var(--color-lemon);
    margin: var(--space-2xl) 0;
    padding: var(--space-md) var(--space-xl);
  }
  :global(.project-body blockquote p) {
    font-size: var(--text-lg);
    color: var(--color-heading);
    font-style: italic;
    margin-bottom: var(--space-sm);
  }

  /* Images in the body — same treatment as writing posts */
  :global(.project-body img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-top: var(--space-xl);
    display: block;
  }
  :global(.project-body img + em) {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-slate);
    letter-spacing: 0.08em;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-xl);
    line-height: var(--leading-relaxed);
  }


  /* ── Outcomes & Impact ───────────────────────────────────────────────── */

  .project-outcomes {
    margin-bottom: var(--space-3xl);
  }

  /* Default: single column. --split enables two-column when a quote is present. */
  .project-outcomes-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .project-outcomes-inner--split {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-3xl);
  }

  /* ── Left column: testimonial quote ─────────────────────────────────── */

  /* Fixed-width quote column — quote doesn't need to grow beyond ~240px */
  .project-outcomes-quote {
    flex: 0 0 240px;
  }

  /* Large Fraunces italic — same editorial feel as the project reflection */
  .project-outcomes-quote-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-regular);
    font-size: var(--text-xl);
    line-height: var(--leading-tight);
    color: var(--color-heading);
    margin-bottom: var(--space-md);
  }

  /* Small muted attribution line below the quote */
  .project-outcomes-quote-attr {
    font-size: var(--text-sm);
    color: var(--color-slate);
    line-height: var(--leading-relaxed);
  }

  /* ── Right column (or full width): outcomes list ─────────────────────── */

  .project-outcomes-list {
    list-style: none;
    padding: 0;
    flex: 1;       /* take remaining space when in two-column layout */
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* Each item: emoji + bold label — description, with lemon left border */
  .project-outcome-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    padding-left: var(--space-lg);
    border-left: 3px solid var(--color-lemon);
    color: var(--color-charcoal);
    line-height: var(--leading-loose);
    font-size: var(--text-base);
  }

  /* Emoji doesn't need to shrink — keep it full size */
  .project-outcome-emoji {
    flex-shrink: 0;
  }

  /* Bold label inherits heading color so it stands out from the description */
  .project-outcome-label {
    color: var(--color-heading);
  }

  /* Stack to single column on mobile — 240px quote column is too narrow */
  @media (max-width: 600px) {
    .project-outcomes-inner--split {
      flex-direction: column;
    }
    .project-outcomes-quote {
      flex: none;
    }
  }


  /* ── Project Reflection ──────────────────────────────────────────────── */
  /* Intentionally softer than the other sections — this is personal voice,
     not a structured data section. No bold UI heading, no divider line. */

  .project-reflection {
    /* Extra space above separates it clearly from Outcomes */
    margin-top: var(--space-4xl);
    padding-top: var(--space-3xl);
    border-top: 1px solid var(--color-slate);
  }

  /* Small label above the title — "Project Reflection" in muted caps */
  .project-reflection-eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-slate);
    margin-bottom: var(--space-md);
  }

  /* The custom title — display font, lighter weight, not a bold heading.
     Uses --font-display (Fraunces) so it feels editorial rather than structural. */
  .project-reflection-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-medium);  /* medium, not bold — softer feel */
    color: var(--color-heading);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-xl);
  }

  .project-reflection-body {
    font-size: var(--text-base);
    color: var(--color-charcoal);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-md);
    max-width: 60ch; /* tighter measure for reflective writing — more intimate */
  }
</style>
