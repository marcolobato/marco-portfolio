---
// Footer.astro — Shared footer component
// Import this on any page: import Footer from '../components/Footer.astro';
// Then use it as: <Footer />
---

<footer class="footer">
  <div class="container">

    <!-- Top row: identity left, contact right -->
    <div class="footer-top">
      <div class="footer-identity">
        <span class="footer-name">
          Marco Lobato
          <!-- Globato icon — a small personality detail with a gentle wobble.
               Animation is disabled for users who prefer reduced motion. -->
          <img src="/globato-favicon.svg" alt="" class="footer-lobo" aria-hidden="true" />
        </span>
      </div>
      <ul class="footer-links">
        <li>
          <a href="mailto:marcolobato.ux@gmail.com">
            marcolobato.ux@gmail.com
          </a>
        </li>
        <li>
          <a
            href="https://linkedin.com/in/marcolobato"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
        </li>
      </ul>
    </div>

    <!-- Divider -->
    <hr class="footer-divider" />

    <!-- Bottom row: copyright left, back to top right -->
    <div class="footer-bottom">
      <span class="footer-copyright">© 2026 Marco Lobato</span>
      <a href="#" class="footer-top-link">Back to top ↑</a>
    </div>

  </div>
</footer>

<!-- Footer styles live in src/styles/global.css — section 10. Footer -->
