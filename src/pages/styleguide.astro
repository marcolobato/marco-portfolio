---
// styleguide.astro — Marco Lobato Design System
// This page is both documentation and a live exhibit.
// Every color, type style, and component shown here is the real thing —
// built with the same tokens and global styles used across the whole site.
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Style Guide — Marco Lobato</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,700;1,9..144,400&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>

    <Nav />


    <main class="sg-main">

      <!-- ===================================================================
           PAGE HEADER
           =================================================================== -->
      <header class="sg-header">
        <p class="section-label">Living Document</p>
        <h1>Design System</h1>
        <p class="sg-header-desc">
          The tokens, typography, and components that make up this portfolio.
          This page is built with the same code it documents.
        </p>
      </header>


      <!-- ===================================================================
           SECTION: COLORS
           =================================================================== -->
      <section class="sg-section">
        <h2 class="sg-section-title">Color</h2>
        <p class="sg-section-desc">
          All colors are defined as CSS custom properties in
          <code>tokens.css</code>. Nothing in this project uses a hardcoded
          hex value — every color reference points back to one of these tokens.
        </p>

        <h3 class="sg-subsection-title">Brand palette</h3>
        <div class="sg-swatches">

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background-color: var(--color-navy); border: 1px solid var(--color-slate);"></div>
            <p class="sg-swatch-name">Navy</p>
            <code class="sg-swatch-token">--color-navy</code>
            <p class="sg-swatch-use">Headings, footer background</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background-color: var(--color-royal-blue);"></div>
            <p class="sg-swatch-name">Royal Blue</p>
            <code class="sg-swatch-token">--color-royal-blue</code>
            <p class="sg-swatch-use">Links, hover states, hero title</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background-color: var(--color-lemon); border: 1px solid var(--color-slate);"></div>
            <p class="sg-swatch-name">Lemon</p>
            <code class="sg-swatch-token">--color-lemon</code>
            <p class="sg-swatch-use">Section labels, footer accents</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background-color: var(--color-citrine); border: 1px solid var(--color-slate);"></div>
            <p class="sg-swatch-name">Citrine</p>
            <code class="sg-swatch-token">--color-citrine</code>
            <p class="sg-swatch-use">Secondary accent, available</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background-color: var(--color-slate);"></div>
            <p class="sg-swatch-name">Slate</p>
            <code class="sg-swatch-token">--color-slate</code>
            <p class="sg-swatch-use">Borders, dividers, placeholders</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background-color: var(--color-charcoal);"></div>
            <p class="sg-swatch-name">Charcoal</p>
            <code class="sg-swatch-token">--color-charcoal</code>
            <p class="sg-swatch-use">Body text</p>
          </div>

        </div>

        <h3 class="sg-subsection-title">Surfaces</h3>
        <div class="sg-swatches">

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background-color: var(--color-white); border: 1px solid var(--color-slate);"></div>
            <p class="sg-swatch-name">White</p>
            <code class="sg-swatch-token">--color-white</code>
            <p class="sg-swatch-use">Primary page background</p>
          </div>

          <div class="sg-swatch">
            <div class="sg-swatch-color" style="background-color: var(--color-surface); border: 1px solid var(--color-slate);"></div>
            <p class="sg-swatch-name">Surface</p>
            <code class="sg-swatch-token">--color-surface</code>
            <p class="sg-swatch-use">Alternate section backgrounds</p>
          </div>

        </div>
      </section>


      <!-- ===================================================================
           SECTION: TYPOGRAPHY
           =================================================================== -->
      <section class="sg-section">
        <h2 class="sg-section-title">Typography</h2>
        <p class="sg-section-desc">
          All type is set in <strong>Fraunces</strong> — a variable serif with
          optical sizes and a warm, editorial character. Sizes come from a
          base-16 scale defined in <code>global.css</code>.
        </p>

        <!-- Type scale samples -->
        <div class="sg-type-scale">

          <div class="sg-type-row">
            <span class="sg-type-meta">--text-6xl · 80px · Bold</span>
            <p class="sg-type-sample" style="font-size: var(--text-6xl); font-weight: var(--weight-bold); line-height: var(--leading-tight);">Display</p>
          </div>

          <div class="sg-type-row">
            <span class="sg-type-meta">--text-5xl · 56px · Bold · h1</span>
            <h1 class="sg-type-sample-heading">Page Title</h1>
          </div>

          <div class="sg-type-row">
            <span class="sg-type-meta">--text-4xl · 40px · Bold · h2</span>
            <h2 class="sg-type-sample-heading">Section Heading</h2>
          </div>

          <div class="sg-type-row">
            <span class="sg-type-meta">--text-3xl · 32px · Bold · h3</span>
            <h3 class="sg-type-sample-heading">Subsection</h3>
          </div>

          <div class="sg-type-row">
            <span class="sg-type-meta">--text-2xl · 24px · Medium</span>
            <p style="font-size: var(--text-2xl); font-weight: var(--weight-medium); color: var(--color-navy); margin: 0;">Hero title / Now statement</p>
          </div>

          <div class="sg-type-row">
            <span class="sg-type-meta">--text-lg · 18px · Regular · Body lead</span>
            <p style="font-size: var(--text-lg); margin: 0;">I'm a product designer who works at the intersection of emerging technology and human experience.</p>
          </div>

          <div class="sg-type-row">
            <span class="sg-type-meta">--text-base · 16px · Regular · Body</span>
            <p style="margin: 0;">Default body text. Comfortable for long-form reading. Max-width is capped at 65ch to maintain an ideal line length.</p>
          </div>

          <div class="sg-type-row">
            <span class="sg-type-meta">--text-sm · 14px · Regular · UI text</span>
            <p style="font-size: var(--text-sm); margin: 0;">Navigation links, footer links, secondary labels.</p>
          </div>

          <div class="sg-type-row">
            <span class="sg-type-meta">--text-xs · 12px · Bold · Label</span>
            <p class="section-label" style="margin: 0;">Section Label</p>
          </div>

        </div>
      </section>


      <!-- ===================================================================
           SECTION: COMPONENTS
           Each component is shown as it actually appears on the site,
           using the exact same HTML structure and class names.
           =================================================================== -->
      <section class="sg-section">
        <h2 class="sg-section-title">Components</h2>
        <p class="sg-section-desc">
          Every component below uses the same HTML and class names as the live
          portfolio. There is no separate "demo" version — what you see here
          is the real component.
        </p>


        <!-- Component: Section Label -->
        <div class="sg-component">
          <h3 class="sg-component-title">Section Label</h3>
          <p class="sg-component-desc">
            A small lemon pill used to introduce each major section.
            Built with <code>display: inline-block</code> and
            <code>background-color: var(--color-lemon)</code>.
            Lemon is used nowhere else on the page at full saturation —
            this constraint keeps it feeling like a signal, not decoration.
          </p>
          <div class="sg-component-preview">
            <p class="section-label">Selected Work</p>
          </div>
          <pre class="sg-code"><code>&lt;p class="section-label"&gt;Selected Work&lt;/p&gt;</code></pre>
        </div>


        <!-- Component: Nav -->
        <div class="sg-component">
          <h3 class="sg-component-title">Navigation</h3>
          <p class="sg-component-desc">
            Top bar with name on the left and anchor links on the right.
            On screens 768px and smaller, the links collapse into a hamburger
            menu that toggles open and closed. Links use
            <code>/#section</code> anchors so they work correctly from any page,
            not just the homepage. <code>aria-current="page"</code> is applied
            automatically to the active link.
          </p>
          <div class="sg-component-preview sg-component-preview--flush">
            <Nav />
          </div>
          <pre class="sg-code"><code>import Nav from '../components/Nav.astro';

&lt;Nav /&gt;</code></pre>
        </div>


        <!-- Component: Project Card -->
        <div class="sg-component">
          <h3 class="sg-component-title">Project Card</h3>
          <p class="sg-component-desc">
            Used in the Work section to display a project. Image placeholder
            uses <code>aspect-ratio: 4 / 3</code> to stay proportional at
            any width. Cards sit in a flex row with <code>flex: 1</code> so
            they share space equally regardless of content length.
          </p>
          <div class="sg-component-preview">
            <div class="sg-card-demo">
              <article class="card">
                <div class="card-image" aria-label="Project image placeholder">
                  <span class="card-image-label">[ image ]</span>
                </div>
                <div class="card-body">
                  <h3 class="card-title">Project title goes here</h3>
                </div>
              </article>
            </div>
          </div>
          <pre class="sg-code"><code>&lt;article class="card"&gt;
  &lt;div class="card-image"&gt;
    &lt;span class="card-image-label"&gt;[ image ]&lt;/span&gt;
  &lt;/div&gt;
  &lt;div class="card-body"&gt;
    &lt;h3 class="card-title"&gt;Project title&lt;/h3&gt;
  &lt;/div&gt;
&lt;/article&gt;</code></pre>
        </div>


        <!-- Component: Footer -->
        <div class="sg-component">
          <h3 class="sg-component-title">Footer</h3>
          <p class="sg-component-desc">
            Navy panel at the bottom of the page — the strongest use of the
            brand color. Lemon is used as the name accent, creating a bookend
            with the lemon section labels above. On mobile, name and links
            stack vertically and center-align. The component itself has no
            <code>margin-top</code> — spacing is set at the page level so it
            can be dropped onto any page without side effects.
          </p>
          <div class="sg-component-preview sg-component-preview--flush">
            <Footer />
          </div>
          <pre class="sg-code"><code>import Footer from '../components/Footer.astro';

&lt;Footer /&gt;</code></pre>
        </div>

      </section>
    </main>

    <Footer />

  </body>
</html>


<style>
  /* ==========================================================================
     styleguide.astro — page-specific layout styles
     Reuses class names from index.astro where components are shown live.
     ========================================================================== */

  /* Nav, Footer, and .container styles live in their component files
     or in global.css — no duplication needed here. */

  /* Section label pill — same as index.astro */
  .section-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-navy);
    background-color: var(--color-lemon);
    padding: var(--space-2xs) var(--space-sm);
    border-radius: 2px;
    margin-bottom: var(--space-md);
    max-width: none;
  }

  /* Card components — same as index.astro */
  .card {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: var(--color-white);
    border: 2px dashed var(--color-slate);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
  }
  .card-image-label {
    font-size: var(--text-xs);
    color: var(--color-slate);
    letter-spacing: 0.08em;
  }
  .card-body { flex: 1; }
  .card-title {
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
  }

  /* ------------------------------------------------------------------
     STYLEGUIDE LAYOUT
     Everything below is specific to this page only.
  ------------------------------------------------------------------ */
  .sg-main {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--space-xl);
    padding-bottom: var(--space-4xl);
  }

  /* Page header */
  .sg-header {
    padding-block: var(--space-3xl);
    border-bottom: 1px solid var(--color-slate);
    margin-bottom: var(--space-3xl);
  }
  .sg-header-desc {
    font-size: var(--text-lg);
    color: var(--color-charcoal);
    max-width: 52ch;
    margin-bottom: 0;
  }

  /* Sections */
  .sg-section {
    margin-bottom: var(--space-4xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-slate);
  }
  .sg-section-title {
    /* h2 from global.css — override margin only */
    margin-bottom: var(--space-sm);
  }
  .sg-section-desc {
    max-width: 60ch;
    margin-bottom: var(--space-2xl);
    color: var(--color-charcoal);
  }
  .sg-subsection-title {
    /* h3 from global.css — smaller, used as a label within a section */
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-charcoal);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-lg);
    margin-top: var(--space-2xl);
  }

  /* Color swatches */
  .sg-swatches {
    display: flex;
    flex-wrap: wrap; /* wraps to next line on narrow viewports */
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }
  .sg-swatch {
    width: 140px;
  }
  .sg-swatch-color {
    width: 100%;
    height: 80px;
    border-radius: 4px;
    margin-bottom: var(--space-xs);
  }
  .sg-swatch-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-navy);
    margin-bottom: var(--space-2xs);
  }
  .sg-swatch-token {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-royal-blue);
    font-family: monospace;
    margin-bottom: var(--space-2xs);
  }
  .sg-swatch-use {
    font-size: var(--text-xs);
    color: var(--color-charcoal); /* charcoal instead of slate — readable at small size on white */
    margin-bottom: 0;
    max-width: none;
  }

  /* Typography scale */
  .sg-type-scale {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sg-type-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-block: var(--space-lg);
    border-bottom: 1px solid var(--color-surface);
  }
  .sg-type-meta {
    font-size: var(--text-xs);
    color: var(--color-charcoal); /* charcoal instead of slate — readable at small size on white */
    font-family: monospace;
    letter-spacing: 0.04em;
  }
  /* Prevent global.css heading margins from affecting type samples */
  .sg-type-sample-heading {
    margin: 0;
  }
  .sg-type-sample {
    margin: 0;
    max-width: none;
  }

  /* Component previews */
  .sg-component {
    margin-bottom: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-surface);
  }
  .sg-component-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-navy);
    margin-bottom: var(--space-xs);
  }
  .sg-component-desc {
    max-width: 60ch;
    color: var(--color-charcoal);
    margin-bottom: var(--space-lg);
  }
  .sg-component-preview {
    background-color: var(--color-surface);
    border-radius: 4px;
    padding: var(--space-2xl);
    margin-bottom: var(--space-md);
  }
  /* Flush variant removes padding — used for full-width components like nav/footer */
  .sg-component-preview--flush {
    padding: 0;
    overflow: hidden; /* clips the border-radius on child elements */
  }

  /* Single-card preview — constrain width so it doesn't stretch */
  .sg-card-demo {
    max-width: 320px;
  }

  /* Code snippets */
  .sg-code {
    background-color: var(--color-navy);
    color: var(--color-slate);
    font-size: var(--text-xs);
    line-height: var(--leading-loose);
    padding: var(--space-lg);
    border-radius: 4px;
    overflow-x: auto; /* scroll horizontally if code is wider than the container */
    white-space: pre;
  }
  .sg-code code {
    font-family: monospace;
  }

  /* Inline code in prose */
  code {
    font-family: monospace;
    font-size: 0.9em;
    background-color: var(--color-surface);
    color: var(--color-royal-blue);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }
  /* Don't apply inline style inside code blocks */
  .sg-code code {
    background: none;
    color: inherit;
    padding: 0;
  }
</style>
