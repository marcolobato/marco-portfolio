---
// ProjectCard.astro — A single project card used in the Work section.
// Usage: <ProjectCard title="Project title goes here" />
// Styles live in src/styles/global.css — section 8. Project Card

const { title, image } = Astro.props;
---

<article class="card">
  {image
    ? <img src={image} alt={title} class="card-img" />
    : <div class="card-image" aria-label="Project image placeholder">
        <span class="card-image-label">[ image ]</span>
      </div>
  }
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
  </div>
</article>
