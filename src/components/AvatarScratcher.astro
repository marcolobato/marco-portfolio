---
import Button from './Button.astro';
// AvatarScratcher.astro
// A canvas-based scratch-to-reveal interaction for the hero photo.
//
// HOW IT WORKS:
// - The bottom layer is avatar-scratch-2.png (the revealed expression), always visible.
// - The top layer is a <canvas> with avatar-scratch-1.png drawn onto it.
// - When you click + drag, the canvas pixels are "erased" using the
//   `destination-out` compositing mode, revealing the image below.
// - Touch events mirror mouse events so it works on mobile too.
---

<!--
  STRUCTURE OVERVIEW:
  .scratcher-wrapper        — clips both layers to rounded corners
    <img>                   — bottom layer: always visible, revealed as you scratch
    <canvas>                — top layer: gets erased on click + drag
    .scratcher-hint         — "scratch me" text, fades out on first interaction
  .scratcher-controls       — brush size slider + reset button below the image
-->

<div class="scratcher-wrapper hero-photo">

  <!-- Bottom layer: the image that gets revealed. Always sitting underneath. -->
  <img
    src="/avatar-scratcher/avatar-scratch-2.png"
    alt="Marco Lobato, alternate expression"
    class="scratcher-base"
  />

  <!-- Top layer: drawn on canvas so we can erase parts of it selectively. -->
  <canvas class="scratcher-canvas" id="scratchCanvas"></canvas>

  <!-- Hint overlay: curved coin inscription along the bottom arc.
       SVG <textPath> curves "scratch the surface" along the inside bottom of the circle —
       exactly like text stamped around the rim of a coin.
       The JS fade (hint.style.opacity = '0') works identically — SVG respects opacity. -->
  <svg
    class="scratcher-hint"
    id="scratchHint"
    viewBox="0 0 200 200"
    xmlns="http://www.w3.org/2000/svg"
    aria-label="scratch the surface"
  >
    <defs>
      <!--
        bottomArc: a ∪-shaped dip at the bottom of the image — like the text
        stamped on the inside bottom rim of a coin.

        HOW IT WORKS:
        We use the image's own circle — center (100, 100), radius 90 (10px inset
        from the image edge). This makes the text curvature match the image border.

        Circle center: (100, 100).  Radius: 90px.
        Start:  (38, 165)  — lower-left, on the image circle.
        End:    (162, 165) — lower-right, on the image circle.
        Lowest: (100, 190) — center of the arc, 25px below the endpoints.
        large-arc-flag=0: take the SHORT ~87° arc directly through the bottom.
        sweep-flag=0: empirically confirmed to produce the ∪ (downward) arc.
          sweep=1 produces the ∩ (upward) arc for this configuration.
        At the lowest point the path direction is rightward →
          letter tops point upward toward the image center → readable ✓
        Arc length ≈ 137px — enough for "scratch the surface" at 11px ✓
      -->
      <path id="bottomArc" d="M 38 165 A 90 90 0 0 0 162 165" />
    </defs>

    <text>
      <!--
        startOffset="50%" + text-anchor="middle" = text centered on the arc.
        The browser measures the arc length (~172px) and places the midpoint of the
        text string at the 50% position, giving perfect visual centering.
      -->
      <textPath href="#bottomArc" startOffset="50%" text-anchor="middle">
        scratch the surface
      </textPath>
    </text>
  </svg>

</div>

<!-- Controls: sits below the image, minimal and clean -->
<div class="scratcher-controls">

  <!-- "Coin size" label — plain text, no longer a <label> wrapping the input
       since the input now lives inside .scratcher-stepper instead. -->
  <span class="scratcher-label">Scratch size</span>

  <!-- Stepper group: minus button + range slider + plus button.
       Keeping these three together in their own flex row makes it clear
       they all control the same thing. -->
  <div class="scratcher-stepper">

    <!-- Decrease: subtracts 10 from the slider value (min 0) -->
    <span id="brushDecrease">
      <Button
        variant="secondary"
        icon='<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>'
      />
    </span>

    <input type="range" id="brushSize" min="0" max="100" value="50" />

    <!-- Increase: adds 10 to the slider value (max 100) -->
    <span id="brushIncrease">
      <Button
        variant="secondary"
        icon='<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>'
      />
    </span>

  </div>

  <!-- Reset: redraws the top image, restoring the scratch surface. -->
  <span id="resetCanvas">
    <Button
      label="Reset"
      variant="secondary"
      icon='<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>'
    />
  </span>

</div>


<style>
  /* --- Wrapper ----------------------------------------------------------- */
  /* position: relative creates the coordinate space for the absolutely
     positioned children (canvas and base image).
     overflow: hidden clips both layers to the rounded corners — this is
     how we get a rounded canvas without complex clipping paths. */
  .scratcher-wrapper {
    position: relative;
    /* width, height, border-radius, margin-bottom come from .hero-photo in global.css */
    /* Custom coin cursor.
       CSS cursor: url() accepts an SVG data URI but cannot read CSS custom properties
       (var(--color-lemon) etc.), so the hex values are hardcoded here as an exception.
       #F1F11C = --color-lemon, #CCD418 = --color-citrine (both from tokens.css).
       The two numbers after the URL are the hotspot: 16 16 = center of the 32x32 icon.
       The fallback `crosshair` is used if the browser can't load the custom cursor. */
    /* Isometric 3D coin cursor.
       Built from three layers: top face (bright gold ellipse), side band (mid gold),
       and bottom arc (dark gold). A highlight ellipse adds the glint.
       The whole coin is rotated -15deg to give the tilted, mid-air feel.
       Hex values are hardcoded — CSS variables can't be read inside SVG data URIs. */
    cursor: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 32 32"><g transform="rotate(-15 16 16)"><path d="M 2,15 A 14,6 0 0,0 30,15 L 30,22 A 14,6 0 0,1 2,22 Z" fill="%23C48010"/><ellipse cx="16" cy="22" rx="14" ry="6" fill="%23956008"/><ellipse cx="16" cy="15" rx="14" ry="6" fill="%23F5C030"/><ellipse cx="11" cy="12.5" rx="5" ry="2" fill="%23FFE460" opacity="0.65"/><ellipse cx="16" cy="15" rx="9" ry="3.5" fill="none" stroke="%23C88010" stroke-width="1"/></g></svg>') 16 16, crosshair;
  }

  /* --- Bottom image layer ----------------------------------------------- */
  /* Fills the wrapper completely. object-fit: cover + object-position: center top
     mirrors the same cropping logic as the original hero photo. */
  .scratcher-base {
    position: absolute;
    inset: 0;           /* shorthand for top:0 right:0 bottom:0 left:0 */
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* --- Canvas layer ----------------------------------------------------- */
  /* Sits directly on top of the base image.
     pointer-events: none is NOT set here — we need mouse events on the canvas. */
  .scratcher-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* --- Hint SVG (curved coin inscription) -------------------------------- */
  /* Fills the wrapper exactly like the canvas and base image.
     pointer-events: none so it doesn't block mouse/touch events on the canvas.
     The JS fade still works — SVG elements respect the CSS opacity property. */
  .scratcher-hint {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    transition: opacity 0.5s ease;
    overflow: visible; /* prevents SVG from clipping text near the edges */
  }

  /* SVG text inherits nothing from the page — styles must be set explicitly.
     fill = text color (SVG uses fill, not color).
     filter: drop-shadow() = SVG equivalent of CSS text-shadow. */
  .scratcher-hint text {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.12em;
    fill: white;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.6));
  }

  /* --- Controls --------------------------------------------------------- */
  .scratcher-controls {
    display: flex;
    align-items: center;
    /* flex-wrap: wrap lets items break to a second line if the row is too wide.
       This is the key fix for mobile — the reset button wraps below the stepper
       instead of overflowing off the right edge of the screen. */
    flex-wrap: wrap;
    gap: var(--space-sm);
    /* Pull the controls slightly closer to the image above them */
    margin-top: calc(-1 * var(--space-md));
    margin-bottom: var(--space-xl);
  }

  /* On mobile, shrink the slider and center the controls row */
  @media (max-width: 768px) {
    .scratcher-stepper input[type="range"] {
      width: 56px;
    }

    .scratcher-controls {
      /* justify-content: center pushes all flex children toward the middle,
         so the label + stepper + reset button are visually centered
         below the centered avatar photo */
      justify-content: center;
    }
  }

  /* Label is now a plain inline text node — no flex needed */
  .scratcher-label {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    white-space: nowrap; /* keeps "Coin size" on one line */
  }

  /* Stepper group: minus + slider + plus sit inline, tightly grouped */
  .scratcher-stepper {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  /* The slider itself, nested inside .scratcher-stepper */
  .scratcher-stepper input[type="range"] {
    width: 80px;
    accent-color: var(--color-royal-blue); /* colors the track fill and thumb */
    cursor: pointer;
  }


</style>


<script>
  // -------------------------------------------------------------------------
  // AvatarScratcher — canvas scratch logic
  // -------------------------------------------------------------------------

  const canvas  = document.getElementById('scratchCanvas') as HTMLCanvasElement;
  const ctx     = canvas.getContext('2d')!;
  const hint    = document.getElementById('scratchHint')!;
  const brushInput    = document.getElementById('brushSize') as HTMLInputElement;
  const resetBtn      = document.getElementById('resetCanvas')!;
  const decreaseBtn   = document.getElementById('brushDecrease')!;
  const increaseBtn   = document.getElementById('brushIncrease')!;

  // The canvas internal size must match the CSS display size.
  // 200x200 matches the .hero-photo dimensions in global.css.
  const SIZE = 200;
  canvas.width  = SIZE;
  canvas.height = SIZE;

  // --- Load and draw the top image onto the canvas -----------------------
  // We keep a reference to topImage so we can redraw it when resetting.
  const topImage = new Image();
  topImage.src = '/avatar-scratcher/avatar-scratch-1.png';
  topImage.onload = () => {
    ctx.drawImage(topImage, 0, 0, SIZE, SIZE);
  };

  // --- State -------------------------------------------------------------
  let isDrawing   = false; // true only while the mouse/finger is pressed down
  let hasScratched = false; // used to fade out the hint on first interaction

  // --- Helpers -----------------------------------------------------------

  // getBrushRadius: reads the slider (0–100) and returns the brush radius in pixels.
  //
  // The slider is a 0–100 scale where 50 = "center" = your ideal coin size (diameter 20).
  // We use a two-piece linear map so the range feels natural:
  //   0   → diameter  5  (tiny coin, precise scratching)
  //   50  → diameter 20  (default — centered thumb)
  //   100 → diameter 80  (large coin, fast coverage)
  //
  // Why two pieces? A single line through 0→5 and 100→80 would put the midpoint
  // at diameter ~42.5, not 20. Two segments let us anchor exactly at 50→20.
  function getBrushRadius(): number {
    const v = parseInt(brushInput.value, 10); // 0–100
    let diameter: number;
    if (v <= 50) {
      // First half: 0 → 5, 50 → 20  (gentle ramp for fine control)
      diameter = 5 + (v / 50) * 15;
    } else {
      // Second half: 50 → 20, 100 → 80  (steeper ramp for large sizes)
      diameter = 20 + ((v - 50) / 50) * 60;
    }
    return diameter / 2; // canvas arc() uses radius, not diameter
  }

  // getPos: extracts canvas-relative x/y from either a mouse or touch event.
  // We subtract the canvas's bounding rect to convert from page coords to canvas coords.
  function getPos(e: MouseEvent | TouchEvent): { x: number; y: number } {
    const rect = canvas.getBoundingClientRect();
    // Scale factor: needed if CSS size differs from canvas internal size.
    // Here both are 200px so scaleX/scaleY = 1, but good practice to include.
    const scaleX = SIZE / rect.width;
    const scaleY = SIZE / rect.height;

    if (e instanceof TouchEvent && e.touches.length > 0) {
      return {
        x: (e.touches[0].clientX - rect.left) * scaleX,
        y: (e.touches[0].clientY - rect.top)  * scaleY,
      };
    }
    const me = e as MouseEvent;
    return {
      x: (me.clientX - rect.left) * scaleX,
      y: (me.clientY - rect.top)  * scaleY,
    };
  }

  // scratch: erases a circle at the pointer position.
  // `destination-out` means "draw a transparent hole" — anything drawn
  // in this mode removes pixels from the canvas rather than adding them.
  function scratch(e: MouseEvent | TouchEvent) {
    if (!isDrawing) return;
    const { x, y } = getPos(e);

    ctx.globalCompositeOperation = 'destination-out';
    ctx.beginPath();
    ctx.arc(x, y, getBrushRadius(), 0, Math.PI * 2);
    ctx.fill();

    // Fade the hint out the first time the user scratches
    if (!hasScratched) {
      hasScratched = true;
      hint.style.opacity = '0';
    }
  }

  // --- Mouse events ------------------------------------------------------
  canvas.addEventListener('mousedown', (e) => { isDrawing = true; scratch(e); });
  canvas.addEventListener('mousemove', scratch);
  canvas.addEventListener('mouseup',   () => { isDrawing = false; });
  canvas.addEventListener('mouseleave',() => { isDrawing = false; });

  // --- Touch events (mobile) ---------------------------------------------
  // preventDefault() stops the page from scrolling while scratching.
  canvas.addEventListener('touchstart', (e) => { e.preventDefault(); isDrawing = true;  scratch(e); }, { passive: false });
  canvas.addEventListener('touchmove',  (e) => { e.preventDefault(); scratch(e); },                   { passive: false });
  canvas.addEventListener('touchend',   ()  => { isDrawing = false; });

  // --- Stepper buttons (− and +) -----------------------------------------
  // Each click nudges the slider by a fixed step of 10 (on the 0–100 scale).
  // Math.max/min clamps the result so we never go below 0 or above 100.
  const STEP = 10;
  decreaseBtn.addEventListener('click', () => {
    brushInput.value = String(Math.max(0,   parseInt(brushInput.value, 10) - STEP));
  });
  increaseBtn.addEventListener('click', () => {
    brushInput.value = String(Math.min(100, parseInt(brushInput.value, 10) + STEP));
  });

  // --- Reset button ------------------------------------------------------
  // Clears the canvas, resets compositing mode to normal, and redraws the top image.
  resetBtn.addEventListener('click', () => {
    ctx.globalCompositeOperation = 'source-over'; // back to normal drawing mode
    ctx.clearRect(0, 0, SIZE, SIZE);
    ctx.drawImage(topImage, 0, 0, SIZE, SIZE);
    hint.style.opacity = '1';
    hasScratched = false;
  });
</script>
