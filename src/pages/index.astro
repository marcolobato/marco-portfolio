---
// index.astro — Marco Lobato Portfolio
// Single-page layout: Hero, Work, Now, Footer
// All colors via tokens.css. Typography and reset from global.css.

// In Astro, CSS files in src/ must be imported here in the frontmatter,
// not via a <link> tag. Astro processes this import through its build pipeline.
import '../styles/global.css';
import { getCollection } from 'astro:content';

// Fetch all writing posts and sort them newest first.
// post.data.date is the date field from each post's frontmatter.
const posts = (await getCollection('writing')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Marco Lobato — The Tech Weaver</title>

    <!-- Fraunces from Google Fonts — loaded in two weights we use: 400 and 700 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,700;1,9..144,400&display=swap"
      rel="stylesheet"
    />

    <!-- global.css is imported in the frontmatter above, not here -->
  </head>

  <body>

    <!-- =====================================================================
         NAV
         Simple top bar: name on the left, anchor links on the right.
         Anchors (#work, #now) scroll to sections further down the page.
         ===================================================================== -->
    <nav class="nav">
      <span class="nav-name">Marco Lobato</span>
      <ul class="nav-links">
        <li><a href="#work">Work</a></li>
        <li><a href="#now">Now</a></li>
        <li><a href="#writing">Writing</a></li>
        <li><a href="/styleguide">Style Guide</a></li>
        <li>
          <a href="mailto:marcolobato.ux@gmail.com">Contact</a>
        </li>
      </ul>
    </nav>


    <!-- =====================================================================
         HERO
         Name as the biggest element on the page, then title, then intro.
         ===================================================================== -->
    <section class="hero">
      <div class="container">
        <!-- h1 inherits lemon color + bold weight + tight leading from global.css -->
        <h1 class="hero-name">Marco Lobato</h1>

        <!-- The title is visually distinct — smaller, citrine, medium weight -->
        <p class="hero-title">The Tech Weaver</p>

        <!-- alt="" marks the image as decorative for screen readers.
             This is correct here because the name "Marco Lobato" is already
             in the heading above — repeating it as alt text would be redundant. -->
        <img
          src="/marco.jpg"
          alt=""
          role="presentation"
          class="hero-photo"
        />

        <p class="hero-intro">
          I'm a product designer who works at the intersection of emerging
          technology and human experience. I design interfaces that feel
          calm, capable, and grounded — even when the tech behind them is
          anything but simple.
        </p>
      </div>
    </section>


    <!-- =====================================================================
         WORK
         One featured area with two project cards.
         Image areas are placeholders — replace src and alt when ready.
         ===================================================================== -->
    <section class="work" id="work">
      <div class="container">

        <!-- Section label — small, uppercase, spaced lettering -->
        <p class="section-label">Selected Work</p>

        <!-- Area heading — groups the two cards under a shared theme -->
        <h2 class="area-heading">
          Designing distraction-free<br />multimodal interfaces
        </h2>

        <!-- Cards grid — two cards side by side on wider screens -->
        <div class="cards">

          <!-- Card 1 -->
          <article class="card">
            <!-- Image placeholder: a styled div standing in for a real image.
                 Replace this div with an <img> tag when you have the asset. -->
            <div class="card-image" aria-label="Project image placeholder">
              <span class="card-image-label">[ image ]</span>
            </div>
            <div class="card-body">
              <h3 class="card-title">
                Making Android setup accessible from day one
              </h3>
            </div>
          </article>

          <!-- Card 2 -->
          <article class="card">
            <div class="card-image" aria-label="Project image placeholder">
              <span class="card-image-label">[ image ]</span>
            </div>
            <div class="card-body">
              <h3 class="card-title">
                Keeping people in flow with smarter, more reliable voice
                interactions
              </h3>
            </div>
          </article>

        </div><!-- /.cards -->
      </div><!-- /.container -->
    </section>


    <!-- =====================================================================
         NOW
         A single honest paragraph about what I'm doing right now.
         ===================================================================== -->
    <section class="now" id="now">
      <div class="container">
        <p class="section-label">Now</p>
        <p class="now-text">
          Right now I'm tinkering with AI, building prototypes for experiences
          and tools that take advantage of what's newly possible.
        </p>
      </div>
    </section>


    <!-- =====================================================================
         WRITING
         One card per post. Posts come from src/content/writing/*.md
         Sorted newest first by the date field in each post's frontmatter.
         ===================================================================== -->
    <section class="writing" id="writing">
      <div class="container">
        <p class="section-label">Writing</p>
        <h2 class="writing-heading">Tiny Experiments</h2>
        <p class="writing-desc">
          Hands-on UX explorations and the lessons I uncover along the way.
        </p>

        <div class="writing-cards">
          {posts.map(post => (
            <!-- Each post.slug becomes the URL, e.g. /writing/learning-in-public -->
            <a href={`/writing/${post.slug}`} class="writing-card">
              <!-- Image placeholder — replace with post.data.image when you have cover images -->
              <div class="writing-card-image" aria-hidden="true">
                <span class="writing-card-image-label">[ image ]</span>
              </div>
              <div class="writing-card-body">
                <h3 class="writing-card-title">{post.data.title}</h3>
                <p class="writing-card-desc">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- =====================================================================
         FOOTER
         Email and LinkedIn. Both open outside the site.
         ===================================================================== -->
    <footer class="footer">
      <div class="container footer-inner">
        <span class="footer-name">Marco Lobato</span>
        <ul class="footer-links">
          <li>
            <a href="mailto:marcolobato.ux@gmail.com">
              marcolobato.ux@gmail.com
            </a>
          </li>
          <li>
            <a
              href="https://linkedin.com/in/marcolobato"
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </footer>

  </body>
</html>


<!-- ==========================================================================
     PAGE-LEVEL STYLES
     These styles are specific to index.astro layout only.
     They do NOT duplicate anything in global.css.
     All colors use tokens from tokens.css.
     ========================================================================== -->
<style>
  /* ------------------------------------------------------------------
     Layout container
     Centers content and sets a max readable width.
     padding-inline = left + right padding combined.
  ------------------------------------------------------------------ */
  .container {
    max-width: 960px;
    margin-inline: auto; /* centers the block horizontally */
    padding-inline: var(--space-xl);
  }


  /* ------------------------------------------------------------------
     NAV
  ------------------------------------------------------------------ */
  .nav {
    display: flex;
    justify-content: space-between; /* name left, links right */
    align-items: center;
    padding-block: var(--space-lg);   /* vertical padding */
    padding-inline: var(--space-xl);  /* horizontal padding */
    max-width: 960px;
    margin-inline: auto;
  }

  .nav-name {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-sm);
    color: var(--color-navy); /* navy on white — clear and grounded */
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: var(--space-lg);
  }

  .nav-links a {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--color-royal-blue); /* royal-blue hover — readable on white */
  }


  /* ------------------------------------------------------------------
     HERO
  ------------------------------------------------------------------ */
  .hero {
    padding-block: var(--space-4xl); /* lots of breathing room at top */
  }

  .hero-name {
    /* h1 size and color come from global.css — we only control spacing here */
    margin-bottom: var(--space-sm);
  }

  .hero-title {
    font-size: var(--text-2xl);
    font-weight: var(--weight-medium);
    color: var(--color-royal-blue); /* royal-blue reads clearly on white, adds energy */
    margin-bottom: var(--space-xl);
    max-width: none;
  }

  .hero-photo {
    width: 200px;
    height: 200px;
    object-fit: cover;       /* crops the image to fill the box without stretching */
    object-position: center top; /* anchors the crop to the face, not the middle of the body */
    border-radius: 12px;     /* rounded rectangle — softer than a hard corner, less formal than a circle */
    margin-bottom: var(--space-xl);
  }

  .hero-intro {
    font-size: var(--text-lg);
    color: var(--color-charcoal);
    max-width: 52ch;
    line-height: var(--leading-loose);
    margin-bottom: 0;
  }


  /* ------------------------------------------------------------------
     SECTION LABEL
     The small uppercase label above headings (e.g. "Selected Work", "Now")
  ------------------------------------------------------------------ */
  .section-label {
    /* Lemon pill — the small geometric accent inspired by the reference.
       A background-color turns the label into a badge-like chip. */
    display: inline-block; /* shrinks to fit the text width */
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-navy);
    background-color: var(--color-lemon); /* lemon as a small punchy accent */
    padding: var(--space-2xs) var(--space-sm);
    border-radius: 2px;
    margin-bottom: var(--space-md);
    max-width: none;
  }


  /* ------------------------------------------------------------------
     WORK SECTION
  ------------------------------------------------------------------ */
  .work {
    padding-block: var(--space-3xl);
    background-color: var(--color-surface); /* subtle off-white panel — separates work from hero */
  }

  .area-heading {
    /* h2 size/color from global.css — we control bottom spacing only */
    margin-bottom: var(--space-2xl);
  }

  /* Cards: side by side with equal width. gap adds space between them. */
  .cards {
    display: flex;
    gap: var(--space-xl);
  }

  .card {
    flex: 1; /* each card takes equal space regardless of content */
    display: flex;
    flex-direction: column; /* image on top, text below */
  }

  /* Image placeholder — light bg with dashed border, consistent with hero photo placeholder */
  .card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: var(--color-white);
    border: 2px dashed var(--color-slate);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
  }

  .card-image-label {
    font-size: var(--text-xs);
    color: var(--color-slate);
    letter-spacing: 0.08em;
  }

  .card-body {
    flex: 1;
  }

  .card-title {
    /* h3 color and weight from global.css — override size for cards */
    font-size: var(--text-xl);
    line-height: var(--leading-normal); /* slightly looser than heading default for multi-line */
  }


  /* ------------------------------------------------------------------
     NOW SECTION
  ------------------------------------------------------------------ */
  .now {
    padding-block: var(--space-3xl);
    border-top: 1px solid var(--color-slate);
  }

  .now-text {
    font-size: var(--text-2xl);
    color: var(--color-charcoal);
    max-width: 44ch;
    line-height: var(--leading-normal);
    margin-bottom: 0;
  }


  /* ------------------------------------------------------------------
     FOOTER
  ------------------------------------------------------------------ */
  /* Footer — navy panel like the bold color block in the reference site.
     This is where navy earns its place: a strong closing statement. */
  .footer {
    background-color: var(--color-navy);
    padding-block: var(--space-2xl);
    margin-top: var(--space-3xl);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-lemon); /* lemon on navy — the most vivid accent on the page */
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer-links a {
    font-size: var(--text-sm);
    color: var(--color-slate);
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--color-lemon);
  }


  /* ------------------------------------------------------------------
     WRITING SECTION
  ------------------------------------------------------------------ */
  .writing {
    padding-block: var(--space-3xl);
    border-top: 1px solid var(--color-slate);
  }

  .writing-heading {
    margin-bottom: var(--space-sm);
  }

  .writing-desc {
    max-width: 52ch;
    margin-bottom: var(--space-2xl);
  }

  /* Three cards in a row — same flex approach as the work cards */
  .writing-cards {
    display: flex;
    gap: var(--space-lg);
  }

  /* The whole card is a link — no underline, inherits text color */
  .writing-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    background-color: var(--color-white);
    border: 1px solid var(--color-surface);
    border-radius: 12px;
    overflow: hidden;  /* clips the image to the card's rounded corners */
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  /* Subtle lift on hover — signals the card is clickable */
  .writing-card:hover {
    box-shadow: 0 4px 24px rgba(8, 31, 93, 0.08); /* navy-tinted shadow at low opacity */
    transform: translateY(-2px);
  }

  /* Image area — surface background until real cover images are added */
  .writing-card-image {
    width: 100%;
    aspect-ratio: 16 / 9; /* wider crop than project cards — better for article covers */
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0; /* prevents the image area from compressing */
  }

  .writing-card-image-label {
    font-size: var(--text-xs);
    color: var(--color-slate);
    letter-spacing: 0.08em;
  }

  .writing-card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .writing-card-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-navy);
    line-height: var(--leading-normal);
  }

  .writing-card-desc {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    line-height: var(--leading-normal);
    margin-bottom: 0;
    max-width: none;
  }
</style>
