---
// experiments.astro — Field Notes archive page
// The /experiments URL is preserved for backwards compatibility, but the page
// is titled "Field Notes" — see the BaseLayout title and h1 below.
//
// Sections, top to bottom:
//   1. Header (page title + description)
//   2. Multimodal work — featured cards (3 entries, pulled from writing collection)
//   3. Past entries — older Medium articles (added in a follow-up commit)
//   4. Design concept glossary — terms + one-line definitions (added in a follow-up commit)
import '../styles/global.css';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

// All writing posts — fetched once, reused across both sections below.
const allPosts = await getCollection('writing');

// Multimodal work — three featured experiments. Same ids as the homepage
// Field Notes section, duplicated here intentionally so each page can pick
// its own featured set if they ever diverge.
const multimodalIds = ['privacysim', 'pharmassist', 'ai-broken-in-denim'];
const multimodalEntries = allPosts
  .filter(post => multimodalIds.includes(post.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Past entries — earlier writing on AI, design, and physical spaces.
// These are Medium articles ported into the writing collection; they live
// in Past entries (not Multimodal work) to keep the focus on current work.
const pastIds = ['ai-and-design-theory', 'digitizing-physical-spaces', 'learning-in-public'];
const pastEntries = allPosts
  .filter(post => pastIds.includes(post.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Field Notes — Marco Lobato">

  <Nav />

  <main class="sg-main">

    <!-- ===================================================================
         PAGE HEADER
         =================================================================== -->
    <header class="sg-header" style="margin-bottom: var(--space-sm)">
      <p class="section-label">Explorations</p>
      <h1>Field Notes</h1>
      <div class="sg-header-sections">
        <div class="sg-header-section">
          <p class="sg-header-section-title">The full archive</p>
          <p class="sg-header-desc" style="max-width: 72ch;">Log of experiments in interaction design. Each entry documents what I built, what I used to build it, and what I learned. Most include an artifact: a prototype, a video, or something you can try.</p>
        </div>
      </div>
    </header>


    <!-- ===================================================================
         SECTION: MULTIMODAL WORK
         Three featured experiments shown as cards. Reuses the .writing-cards
         grid and .writing-card styles from the homepage Field Notes section.
         Cards link to each post's article page at /writing/{id}.
         =================================================================== -->
    <section class="sg-section" id="multimodal-work" style="padding-top: 0;">

      <h2 style="margin-bottom: var(--space-md);">Multimodal work</h2>

      <p class="sg-header-desc" style="max-width: 72ch; margin-bottom: var(--space-xl);">
        I am evaluating tools to create AI agents and virtual humans powered by the latest AI models, with a focus on designing multimodal communication patterns. I'm interested in how these tools can facilitate more natural interactions between humans and technology.
      </p>

      <!-- Tagline directly above the card grid — labels the cards as the
           "tiny experiments" referenced in the description above. -->
      <p class="sg-header-section-title" style="margin-bottom: var(--space-md);">
        Tiny experiments in multimodal AI interaction design
      </p>

      <div class="writing-cards">
        {multimodalEntries.map(post => (
          <a href={`/writing/${post.id}`} class="writing-card">
            <div class="writing-card-image">
              {post.data.image
                ? <img src={post.data.image} alt={post.data.title} class="writing-card-img" />
                : <span class="writing-card-image-label">[ image ]</span>
              }
            </div>
            <div class="writing-card-body">
              <h3 class="writing-card-title">{post.data.title}</h3>
              <p class="writing-card-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Sub-section of Multimodal work: a glossary of patterns surfaced
           across the experiments above. Uses h3 (one level under the section's
           h2) to signal this is part of Multimodal work, not a peer section.
           Styled by the scoped <style> block at the bottom of the file. -->
      <div class="glossary" style="margin-top: var(--space-2xl);">
        <h3 style="margin-bottom: var(--space-md);">Design concept glossary</h3>
        <p class="sg-header-desc" style="max-width: 72ch; margin-bottom: var(--space-lg);">
          Concepts named across the experiments above.
        </p>
        <dl>
          <dt>Deictic privacy</dt>
          <dd>Speaking in words that only resolve with shared context, using pronouns and spatial references ("that," "there," "it") instead of explicit details.</dd>

          <dt>Default-private</dt>
          <dd>Ensuring that sensitive details and personally identifiable information remain protected by making non-disclosure the standard setting.</dd>

          <dt>Channel splitting</dt>
          <dd>Strategically utilizing diverse communication paths to time and tailor content delivery, ensuring messages are optimized for the specific situation and audience.</dd>

          <dt>Show, don't speak</dt>
          <dd>In the context of conversation design, the "show, don't speak" principle utilizes visual aids to convey information. This approach keeps details private or provides necessary context by displaying the specific items or concepts under discussion, rather than relying solely on verbal explanation.</dd>

          <dt>Context-released information</dt>
          <dd>The strategic practice of timing the delivery of information based on an AI's real-time understanding of the user's immediate social or physical environment.</dd>

          <dt>Cooperative recording</dt>
          <dd>A mutual agreement to record and transcribe a dialogue so participants can capture complex spoken details, particularly during consultations with specialists like doctors or pharmacists.</dd>
        </dl>
      </div>

    </section>


    <!-- ===================================================================
         SECTION: PAST ENTRIES
         Earlier writing surfaced as cards. Same style as Multimodal work
         and the homepage Field Notes section.
         =================================================================== -->
    <section class="sg-section" id="past-entries">

      <h2 style="margin-bottom: var(--space-md);">Past entries</h2>

      <div class="writing-cards">
        {pastEntries.map(post => (
          <a href={`/writing/${post.id}`} class="writing-card">
            <div class="writing-card-image">
              {post.data.image
                ? <img src={post.data.image} alt={post.data.title} class="writing-card-img" />
                : <span class="writing-card-image-label">[ image ]</span>
              }
            </div>
            <div class="writing-card-body">
              <h3 class="writing-card-title">{post.data.title}</h3>
              <p class="writing-card-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>

    </section>

  </main>

</BaseLayout>


<!-- Scoped styles for the Design concept glossary inside the Multimodal work
     section. Astro auto-scopes <style> blocks to this component, so these
     selectors don't leak to other pages. -->
<style>
  .glossary dl {
    margin: 0;
    max-width: 72ch;
  }

  .glossary dt {
    font-weight: 500;
    margin-bottom: var(--space-xs);
  }

  /* Reset the browser default 40px indent on <dd>; add comfortable spacing
     between entries and a relaxed line-height so longer definitions read well. */
  .glossary dd {
    margin: 0 0 var(--space-md);
    line-height: var(--leading-relaxed);
  }

  /* Last entry: no bottom margin, so the section padding controls spacing
     into Past entries below. */
  .glossary dd:last-of-type {
    margin-bottom: 0;
  }
</style>
