---
// experiments.astro — Field Notes archive page
// The /experiments URL is preserved for backwards compatibility, but the page
// is titled "Field Notes" — see the BaseLayout title and h1 below.
//
// Sections, top to bottom:
//   1. Header (page title + description)
//   2. Multimodal work — featured cards (3 entries, pulled from writing collection)
//   3. Past entries — older Medium articles (added in a follow-up commit)
//   4. Design concept glossary — terms + one-line definitions (added in a follow-up commit)
import '../styles/global.css';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

// Multimodal work — three featured experiments. Same ids as the homepage
// Field Notes section, duplicated here intentionally so each page can pick
// its own featured set if they ever diverge.
const multimodalIds = ['privacysim', 'pharmassist', 'ai-broken-in-denim'];
const multimodalEntries = (await getCollection('writing'))
  .filter(post => multimodalIds.includes(post.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Field Notes — Marco Lobato">

  <Nav />

  <main class="sg-main">

    <!-- ===================================================================
         PAGE HEADER
         =================================================================== -->
    <header class="sg-header" style="margin-bottom: var(--space-sm)">
      <p class="section-label">Explorations</p>
      <h1>Field Notes</h1>
      <div class="sg-header-sections">
        <div class="sg-header-section">
          <p class="sg-header-section-title">The full archive</p>
          <p class="sg-header-desc" style="max-width: 72ch;">Log of experiments in interaction design. Each entry documents what I built, what I used to build it, and what I learned. Most include an artifact: a prototype, a video, or something you can try.</p>
        </div>
      </div>
    </header>


    <!-- ===================================================================
         SECTION: MULTIMODAL WORK
         Three featured experiments shown as cards. Reuses the .writing-cards
         grid and .writing-card styles from the homepage Field Notes section.
         Cards link to each post's article page at /writing/{id}.
         =================================================================== -->
    <section class="sg-section" id="multimodal-work" style="padding-top: 0;">

      <h2 style="margin-bottom: var(--space-md);">Multimodal work</h2>

      <p class="sg-header-desc" style="max-width: 72ch; margin-bottom: var(--space-xl);">
        I am evaluating tools to create AI agents and virtual humans powered by the latest AI models, with a focus on designing multimodal communication patterns. I'm interested in how these tools can facilitate more natural interactions between humans and technology.
      </p>

      <!-- Tagline directly above the card grid — labels the cards as the
           "tiny experiments" referenced in the description above. -->
      <p class="sg-header-section-title" style="margin-bottom: var(--space-md);">
        Tiny experiments in multimodal AI interaction design
      </p>

      <div class="writing-cards">
        {multimodalEntries.map(post => (
          <a href={`/writing/${post.id}`} class="writing-card">
            <div class="writing-card-image">
              {post.data.image
                ? <img src={post.data.image} alt={post.data.title} class="writing-card-img" />
                : <span class="writing-card-image-label">[ image ]</span>
              }
            </div>
            <div class="writing-card-body">
              <h3 class="writing-card-title">{post.data.title}</h3>
              <p class="writing-card-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>

    </section>

  </main>

</BaseLayout>
