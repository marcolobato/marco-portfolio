---
// index.astro — Marco Lobato Portfolio
// Single-page layout: Hero, Work, Now, Footer
// All colors via tokens.css. Typography and reset from global.css.

// In Astro, CSS files in src/ must be imported here in the frontmatter,
// not via a <link> tag. Astro processes this import through its build pipeline.
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionLabel from '../components/SectionLabel.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Button from '../components/Button.astro';
import Carousel from '../components/Carousel.astro';
import { Badge } from '../components/ui/badge';
import AvatarScratcher from '../components/AvatarScratcher.astro';

// Fetch all writing posts and sort them newest first.
// post.data.date is the date field from each post's frontmatter.
const posts = (await getCollection('writing')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/lobo-favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Marco Lobato — The Tech Weaver</title>

    <!-- Fraunces from Google Fonts — loaded in two weights we use: 400 and 700 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,700;1,9..144,400&display=swap"
      rel="stylesheet"
    />

    <!-- global.css is imported in the frontmatter above, not here -->

    <!-- Anti-flash theme script — MUST be in <head> before any content renders.
         is:inline tells Astro to keep this exactly as written (don't bundle it).
         It runs synchronously so the correct data-theme is set before the browser
         paints anything — no flash of the wrong theme. -->
    <script is:inline>
      (function () {
        // Check if the user has manually chosen a theme before
        var saved = localStorage.getItem('theme');
        // If not, check their OS setting
        var sys = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        // Apply the saved preference, or fall back to the system setting
        document.documentElement.setAttribute('data-theme', saved || sys);
      })();
    </script>
  </head>

  <body>

    <!-- =====================================================================
         NAV
         Simple top bar: name on the left, anchor links on the right.
         Anchors (#work, #now) scroll to sections further down the page.
         ===================================================================== -->
    <Nav />


    <!-- =====================================================================
         HERO
         Name as the biggest element on the page, then title, then intro.
         ===================================================================== -->
    <section class="hero">
      <div class="container">
        <!-- AvatarScratcher replaces the static hero photo.
             Click + drag to scratch away the top image and reveal a second expression. -->
        <AvatarScratcher />

        <!-- h1 inherits lemon color + bold weight + tight leading from global.css -->
        <h1 class="hero-name">Marco Lobato</h1>

        <!-- Subtitle — uses .hero-title from global.css: royal blue, medium weight -->
        <p class="hero-title">Product & UX Design</p>

        <p class="hero-intro">
          My favorite design work is turning powerful technology into something delightfully ordinary that people can trust when it matters most. Getting there takes a lot of scratching beneath the surface.
        </p>

        <!-- Calls to action — rendered as <a> tags since all three navigate somewhere. -->
        <div class="hero-actions">
          <Button label="LinkedIn" href="https://www.linkedin.com/in/marcolobato/" variant="primary" />
          <Button label="Portfolio" href="https://lobato.framer.website/" variant="secondary" />
          <Button label="Resume" href="https://drive.google.com/file/d/1OflI5mnZdGyf6H7m0oQgDKOK5mFuEQ1-/view?usp=sharing" variant="secondary" />
        </div>
      </div>
    </section>


    <!-- =====================================================================
         ABOUT
         Two-column layout: intro text on the left, video on the right.
         The video uses native <video controls> — works on all devices including
         mobile, where hover-to-play is not possible.
         preload="metadata" means the browser loads only the first frame and
         duration info — it does NOT download the whole file until the user presses
         play. This keeps the page fast.
         ===================================================================== -->
    <section class="about" id="about">
      <div class="container">

        <SectionLabel label="About" />

        <div class="about-inner">

          <!-- Video column — silent autoplay loop, no controls.
               autoplay: starts playing immediately on page load.
               loop: restarts when it reaches the end — like a GIF.
               muted: required for autoplay to work in all browsers.
               playsinline: prevents iOS from going full-screen automatically. -->
          <video class="about-video" autoplay loop muted playsinline>
            <source src="/tsocial_lobatoux.mp4" type="video/mp4" />
            Your browser does not support the video tag.
          </video>

          <!-- Text column — role title + short paragraph -->
          <div class="about-text">
            <p class="about-role">Weaving Tech</p>

            <p class="about-body">
              In every project, I enjoy going deep into four things: the technology itself, the domain it belongs to, the people who will use it, and the setting where it all comes together.
            </p>
            <p class="about-closer">Good tech weaving produces experiences people genuinely enjoy.</p>
          </div>

        </div><!-- /.about-inner -->
      </div><!-- /.container -->
    </section>


    <!-- =====================================================================
         EXPERTISE
         A labeled section with a heading, short paragraph, and image carousel.
         The carousel component handles all slide navigation logic.
         ===================================================================== -->
    <section class="expertise" id="expertise">
      <div class="container">

        <SectionLabel label="Expertise" />

        <h2 class="expertise-heading">
          Interaction and User-Centric Product Design
        </h2>

        <p class="expertise-desc">
          I have consistently worked at the edge of new technology, where the biggest design decisions are still unexplored. My work spans the full arc, from early research and prototyping to shipping experiences at scale, across many platforms and interaction modalities.
        </p>

        <!-- Carousel — 7 slides, arrow + dot navigation, no auto-scroll -->
        <Carousel />

      </div>
    </section>


    <!-- =====================================================================
         WORK
         One featured area with two project cards.
         Image areas are placeholders — replace src and alt when ready.
         ===================================================================== -->
    <section class="work" id="work">
      <div class="container">

        <!-- Section label — small, uppercase, spaced lettering -->
        <SectionLabel label="Selected Work" />

        <!-- Area heading — groups the two cards under a shared theme -->
        <h2 class="area-heading">Beyond the Touchscreen</h2>

        <p class="work-desc">
          The thread across my work is keeping people in their flow. The best interfaces never pull you out of what you are doing. These projects go beyond apps. They shape the platform itself, making it work across every way people interact, not just touch. If you are building something where that is the goal, I would like to work on it with you.
        </p>

        <!-- Cards grid — two cards side by side on wider screens -->
        <div class="cards">

          <!-- Card 1 -->
          <ProjectCard title="Setting Up Android Your Way, From the Very First Screen" image="/images/selected-work/selected-work-1.png" />

          <!-- Card 2 -->
          <ProjectCard title="Using Your Phone Entirely by Voice, on Your Terms" image="/images/selected-work/selected-work-2.png" />

        </div><!-- /.cards -->
      </div><!-- /.container -->
    </section>


    <!-- =====================================================================
         CURRENTLY BUILDING
         A section label, heading, and paragraph about active work.
         ===================================================================== -->
    <section class="now" id="now">
      <div class="container">
        <div style="display: flex; align-items: baseline; gap: var(--space-sm);">
          <SectionLabel label="Currently Building" />
          <Badge>New</Badge>
        </div>
        <h2 class="now-heading">Playground</h2>
        <p class="now-text">
          I am building in public here. If you are working on the future of
          consumer electronic interfaces or AI-powered products, let's talk.
          This playground grows over time, starting with the design system
          behind this site and expanding into prototypes as they take shape.
        </p>
        <div class="now-actions">
          <Button label="Visit the playground" href="/playground" variant="primary" />
        </div>
      </div>
    </section>


    <!-- =====================================================================
         WRITING
         One card per post. Posts come from src/content/writing/*.md
         Sorted newest first by the date field in each post's frontmatter.
         ===================================================================== -->
    <section class="writing" id="writing">
      <div class="container">
        <SectionLabel label="Notes" />
        <h2 class="writing-heading">Learning in Public</h2>

        <div class="writing-cards">
          {posts.map(post => (
            <a href={`/writing/${post.id}`} class="writing-card">
              <div class="writing-card-image">
                {post.data.image
                  ? <img src={post.data.image} alt={post.data.title} class="writing-card-img" />
                  : <span class="writing-card-image-label">[ image ]</span>
                }
              </div>
              <div class="writing-card-body">
                <h3 class="writing-card-title">{post.data.title}</h3>
                <p class="writing-card-desc">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- =====================================================================
         FOOTER
         Email and LinkedIn. Both open outside the site.
         ===================================================================== -->
    <!-- footer-spacer owns the top margin — the Footer component itself is margin-free
         so it can be placed on any page without unwanted spacing. -->
    <div class="footer-spacer">
      <Footer />
    </div>

    <!-- Accessibility: respect the user's system "Reduce Motion" setting.
         If enabled, the about video is paused instead of autoplaying.
         window.matchMedia mirrors the same media query you can write in CSS.
         This script runs after the page loads (Astro defers all scripts by default),
         so the video element is guaranteed to exist in the DOM by the time it runs. -->
    <script>
      const video = document.querySelector('.about-video') as HTMLVideoElement;
      if (video && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        video.pause();
      }
    </script>

  </body>
</html>


<!-- All styles live in src/styles/global.css — sections 7–11 -->
