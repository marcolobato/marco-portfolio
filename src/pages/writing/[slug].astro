---
// [slug].astro — Individual post page
// The filename [slug] is a special Astro convention meaning "dynamic route".
// Astro will generate one page per post, e.g. /writing/learning-in-public
// getStaticPaths() tells Astro which slugs exist at build time.

import { getCollection, render } from 'astro:content';
import '../../styles/global.css';
import Nav from '../../components/Nav.astro';

// getStaticPaths runs once at build time and returns one entry per post.
// Each entry becomes a separate page URL.
export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

// props.post is the individual post data passed from getStaticPaths above.
const { post } = Astro.props;

// render() converts the Markdown body into HTML.
const { Content } = await render(post);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title} — Marco Lobato</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,700;1,9..144,400&display=swap"
      rel="stylesheet"
    />

    <!-- Anti-flash theme script — MUST be in <head> before any content renders.
         is:inline tells Astro to keep this exactly as written (don't bundle it). -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        var sys = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', saved || sys);
      })();
    </script>
  </head>

  <body>

    <Nav />

    <main class="post-main">
      <div class="post-container">

        <!-- Back link -->
        <a href="/#writing" class="post-back">← Writing</a>

        <!-- Post header -->
        <header class="post-header">
          <p class="post-date">
            <!-- toLocaleDateString formats the date as "January 15, 2024" -->
            {post.data.date.toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <h1 class="post-title">{post.data.title}</h1>
          <p class="post-description">{post.data.description}</p>
        </header>

        <!-- Cover image — shown if the post's frontmatter includes an `image` field -->
        {post.data.image && (
          <img src={post.data.image} alt={post.data.title} class="post-cover" />
        )}

        <!-- Post body — Content is the rendered Markdown from the .md file -->
        <div class="post-body">
          <Content />
        </div>

      </div>
    </main>

  </body>
</html>


<style>
  /* Nav styles live in src/components/Nav.astro */

  .post-main {
    padding-block: var(--space-3xl);
  }

  .post-container {
    max-width: 680px; /* narrower than the site container — ideal for long-form reading */
    margin-inline: auto;
    padding-inline: var(--space-xl);
  }

  .post-back {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-royal-blue);
    margin-bottom: var(--space-2xl);
    transition: color 0.2s ease;
  }
  .post-back:hover { color: var(--color-navy); }

  .post-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-slate);
  }

  .post-date {
    font-size: var(--text-sm);
    color: var(--color-slate);
    margin-bottom: var(--space-sm);
    max-width: none;
  }

  .post-title {
    /* h1 from global.css */
    margin-bottom: var(--space-md);
  }

  .post-description {
    font-size: var(--text-lg);
    color: var(--color-charcoal);
    margin-bottom: 0;
  }

  /* Post body — styles the rendered Markdown content */
  .post-body h2 { margin-top: var(--space-2xl); margin-bottom: var(--space-md); }
  .post-body h3 { margin-top: var(--space-xl);  margin-bottom: var(--space-sm); }
  .post-body p  { line-height: var(--leading-loose); }

  /* Cover image — full width, rounded, sits between the header and the body */
  .post-cover {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: var(--space-2xl);
    display: block;
  }

  /* Images — full width, rounded corners, breathing room above and below */
  .post-body img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-top: var(--space-xl);
    display: block;
  }

  /* Caption — the italic <em> text that follows each image.
     Smaller, muted, tight top margin so it hugs the image. */
  .post-body img + p > em:only-child {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-slate);
    margin-top: var(--space-xs);
    margin-bottom: var(--space-xl);
    line-height: var(--leading-relaxed);
  }
</style>
